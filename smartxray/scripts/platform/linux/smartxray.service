[Unit]
Description=SmartXray - Xray Server Manager
After=network.target

[Service]
Type=simple
User=nobody
ExecStart=/usr/local/bin/xray run -c /etc/smartxray/config.json
Restart=on-failure
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
