<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.smartxray</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/xray</string>
    <string>run</string>
    <string>-c</string>
    <string>__HOME__/.config/smartxray/config.json</string>
  </array>
  <key>RunAtLoad</key>
  <false/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/.config/smartxray/logs/xray.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.config/smartxray/logs/xray.log</string>
  <key>WorkingDirectory</key>
  <string>__HOME__/.config/smartxray</string>
</dict>
</plist>
