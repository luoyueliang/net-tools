#!/usr/bin/env node
/**
 * xray-ctl — Xray Server 管理工具 (模块化版本)
 * 
 * 这是重构后的主入口文件，使用模块化架构
 */

'use strict';

const { execSync } = require('child_process');
const fs   = require('fs');
const path = require('path');

// ==================== 颜色输出 ====================
const c = {
  red:    s => `\x1b[31m${s}\x1b[0m`,
  green:  s => `\x1b[32m${s}\x1b[0m`,
  yellow: s => `\x1b[33m${s}\x1b[0m`,
  blue:   s => `\x1b[34m${s}\x1b[0m`,
  dim:    s => `\x1b[2m${s}\x1b[0m`,
  bold:   s => `\x1b[1m${s}\x1b[0m`,
};

// ==================== 导入模块 ====================
const database = require('./lib/database');
const config   = require('./lib/config');
const firewall = require('./lib/firewall');
const reality  = require('./lib/reality');
const userManager = require('./lib/user-manager');
const apiServer   = require('./lib/api-server');

// ==================== 常量 ====================
const VERSION     = config.VERSION;
const XRAY_CONF   = config.XRAY_CONF;
const PID_FILE    = config.PID_FILE;
const LOG_FILE    = config.LOG_FILE;
const MIHOMO_OUT  = config.MIHOMO_OUT;
const API_PORT    = config.API_PORT;

// ==================== 工具函数 ====================
function run(cmd) {
  try {
    return execSync(cmd, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] }).trim();
  } catch {
    return '';
  }
}

function readPid() {
  return config.readPid();
}

function writePid(pid) {
  config.writePid(pid);
}

function removePid() {
  config.removePid();
}

function isRunning() {
  return config.isRunning();
}

// ==================== 进程管理 ====================
async function cmdStart() {
  if (isRunning()) {
    console.log(c.yellow('  Xray 已在运行'));
    return;
  }

  // 确保配置文件存在
  if (!fs.existsSync(XRAY_CONF)) {
    console.log(c.yellow('  配置文件不存在，使用默认配置'));
    generateDefaultConfig();
  }

  // 启动 Xray
  try {
    const xrayBin = findXrayBinary();
    if (!xrayBin) {
      console.log(c.red('  ✗ 未找到 xray 可执行文件'));
      return;
    }

    const pid = execSync(`nohup ${xrayBin} run -c ${XRAY_CONF} > ${LOG_FILE} 2>&1 & echo $!`, {
      encoding: 'utf8'
    }).trim();

    writePid(parseInt(pid));
    console.log(c.green(`  ✓ Xray 已启动 (PID: ${pid})`));
  } catch (e) {
    console.log(c.red(`  ✗ 启动失败: ${e.message}`));
  }
}

function cmdStop() {
  const pid = readPid();
  if (!pid) {
    console.log(c.yellow('  Xray 未运行'));
    return;
  }

  try {
    process.kill(pid, 'SIGTERM');
    removePid();
    console.log(c.green('  ✓ Xray 已停止'));
  } catch (e) {
    if (e.code === 'ESRCH') {
      removePid();
      console.log(c.yellow('  Xray 进程不存在，已清理 PID 文件'));
    } else {
      console.log(c.red(`  ✗ 停止失败: ${e.message}`));
    }
  }
}

function cmdStatus() {
  const running = isRunning();
  const pid = readPid();

  console.log(c.bold('\n── Xray 状态 ──────────────────────────────────'));
  console.log(`  状态: ${running ? c.green('运行中') : c.red('已停止')}`);
  if (pid) {
    console.log(`  PID: ${pid}`);
  }

  // 显示用户列表
  const users = database.getAllUsers();
  if (users.length > 0) {
    console.log(c.bold('\n── 用户列表 ──────────────────────────────────'));
    const serverHost = config.getServerHost(database.getSetting);
    const realityConfig = reality.getRealityConfig();

    for (const u of users) {
      const status = u.enabled ? c.green('●') : c.red('○');
      const expire = u.expires_at ? ` (过期: ${new Date(u.expires_at).toLocaleString()})` : '';
      console.log(`  ${status} ${u.name} - 端口: ${u.port}${expire}`);
      console.log(c.dim(`    SOCKS5: socks5://${u.username}:${u.password}@${serverHost}:${u.port}`));
      if (u.http_port) {
        console.log(c.dim(`    HTTP:   http://${u.username}:${u.password}@${serverHost}:${u.http_port}`));
      }
      if (realityConfig.enabled) {
        const link = reality.generateRealityLink(u);
        if (link) console.log(c.dim(`    Reality: ${link}`));
      }
    }
  }

  // 显示 Reality 状态
  const realityConfig = reality.getRealityConfig();
  if (realityConfig.enabled) {
    console.log(c.bold('\n── Reality 状态 ────────────────────────────────'));
    console.log(`  端口: ${realityConfig.port}`);
    console.log(`  公钥: ${realityConfig.publicKey}`);
    console.log(`  SNI: ${realityConfig.serverNames.join(', ')}`);
  }

  console.log('');
}

function cmdReload() {
  if (!isRunning()) {
    console.log(c.yellow('  Xray 未运行'));
    return;
  }

  const pid = readPid();
  try {
    process.kill(pid, 'SIGUSR1');
    console.log(c.green('  ✓ 配置已重载'));
  } catch (e) {
    console.log(c.red(`  ✗ 重载失败: ${e.message}`));
  }
}

function findXrayBinary() {
  const paths = [
    '/usr/local/bin/xray',
    '/usr/bin/xray',
    'xray'
  ];

  for (const p of paths) {
    try {
      execSync(`which ${p}`, { stdio: 'pipe' });
      return p;
    } catch {}
  }

  return null;
}

function generateDefaultConfig() {
  const defaultConfig = {
    log: { loglevel: database.getSetting('log_level', 'warning') },
    inbounds: [],
    outbounds: [{ protocol: 'freedom', tag: 'direct' }],
    routing: { rules: [] }
  };

  fs.writeFileSync(XRAY_CONF, JSON.stringify(defaultConfig, null, 2));
}

// ==================== 用户管理命令 ====================
function cmdUser(args) {
  const sub = args[0];
  const rest = args.slice(1);

  switch (sub) {
    case 'list':
      cmdStatus();
      break;

    case 'add':
      if (rest.length < 1) {
        console.log(c.red('  用法: xray-ctl user add <名称> [用户名] [密码] [有效小时]'));
        return;
      }
      try {
        const user = userManager.addUser({
          name: rest[0],
          username: rest[1],
          password: rest[2],
          hours: rest[3] ? parseInt(rest[3]) : null
        });
        console.log(c.green(`  ✓ 用户已创建: ${user.name}`));
        console.log(`    用户名: ${user.username}`);
        console.log(`    密码: ${user.password}`);
        console.log(`    端口: ${user.port}`);
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'del':
      if (rest.length < 1) {
        console.log(c.red('  用法: xray-ctl user del <名称|ID>'));
        return;
      }
      try {
        const identifier = isNaN(rest[0]) ? rest[0] : parseInt(rest[0]);
        userManager.removeUser(identifier);
        console.log(c.green('  ✓ 用户已删除'));
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'enable':
      if (rest.length < 1) {
        console.log(c.red('  用法: xray-ctl user enable <名称|ID>'));
        return;
      }
      try {
        const identifier = isNaN(rest[0]) ? rest[0] : parseInt(rest[0]);
        userManager.enableUser(identifier);
        console.log(c.green('  ✓ 用户已启用'));
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'disable':
      if (rest.length < 1) {
        console.log(c.red('  用法: xray-ctl user disable <名称|ID>'));
        return;
      }
      try {
        const identifier = isNaN(rest[0]) ? rest[0] : parseInt(rest[0]);
        userManager.disableUser(identifier);
        console.log(c.green('  ✓ 用户已禁用'));
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'passwd':
      if (rest.length < 1) {
        console.log(c.red('  用法: xray-ctl user passwd <名称|ID> [新密码]'));
        return;
      }
      try {
        const identifier = isNaN(rest[0]) ? rest[0] : parseInt(rest[0]);
        const user = userManager.changePassword(identifier, rest[1]);
        console.log(c.green(`  ✓ 密码已更新: ${user.password}`));
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'set-port':
      if (rest.length < 2) {
        console.log(c.red('  用法: xray-ctl user set-port <名称|ID> <socks端口> [http端口]'));
        return;
      }
      try {
        const identifier = isNaN(rest[0]) ? rest[0] : parseInt(rest[0]);
        const user = userManager.setUserPort(identifier, parseInt(rest[1]), rest[2] ? parseInt(rest[2]) : null);
        console.log(c.green(`  ✓ 端口已更新: ${user.port}`));
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    default:
      console.log(c.red('  用法: xray-ctl user <list|add|del|enable|disable|passwd|set-port>'));
  }
}

// ==================== Reality 命令 ====================
function cmdReality(args) {
  const sub = args[0];
  const rest = args.slice(1);

  switch (sub) {
    case 'init':
      try {
        const result = reality.initReality(
          rest[0] ? parseInt(rest[0]) : 443,
          rest[1] || 'www.microsoft.com:443'
        );
        console.log(c.green('  ✓ Reality 已初始化'));
        console.log(`    端口: ${result.port}`);
        console.log(`    公钥: ${result.publicKey}`);
        console.log(`    Short ID: ${result.shortId}`);
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'import':
      if (rest.length < 2) {
        console.log(c.red('  用法: xray-ctl reality import <私钥> <公钥> [端口] [shortId] [dest]'));
        return;
      }
      try {
        const result = reality.importReality(
          rest[0], rest[1],
          rest[2] ? parseInt(rest[2]) : 443,
          rest[3] || null,
          rest[4] || null
        );
        console.log(c.green('  ✓ Reality 密钥已导入'));
        console.log(`    端口: ${result.port}`);
        console.log(`    公钥: ${result.publicKey}`);
      } catch (e) {
        console.log(c.red(`  ✗ ${e.message}`));
      }
      break;

    case 'show':
      console.log(reality.showRealityInfo());
      break;

    case 'disable':
      reality.disableReality();
      console.log(c.green('  ✓ Reality 已禁用'));
      break;

    default:
      console.log(c.red('  用法: xray-ctl reality <init|import|show|disable>'));
  }
}

// ==================== 配置命令 ====================
function cmdConfig(args) {
  const key = args[0];
  const value = args[1];

  if (!key) {
    // 显示所有配置
    const settings = database.getAllSettings();
    console.log(c.bold('\n── 当前配置 ──────────────────────────────────'));
    for (const [k, v] of Object.entries(settings)) {
      if (!k.includes('pass') && !k.includes('private')) {
        console.log(`  ${k}: ${v}`);
      }
    }
    return;
  }

  if (value === undefined) {
    // 获取单个配置
    const val = database.getSetting(key);
    console.log(`  ${key}: ${val}`);
  } else {
    // 设置配置
    database.setSetting(key, value);
    console.log(c.green(`  ✓ ${key} = ${value}`));
  }
}

// ==================== 防火墙命令 ====================
function cmdFirewall(args) {
  const sub = args[0];

  switch (sub) {
    case 'sync':
      const users = database.getAllUsers({ enabledOnly: true });
      const realityConfig = reality.getRealityConfig();
      firewall.syncAllPorts(users, realityConfig);
      console.log(c.green(`  ✓ 已同步 ${users.length} 个用户的端口`));
      break;

    default:
      console.log(c.red('  用法: xray-ctl firewall <sync>'));
  }
}

// ==================== Web UI 命令 ====================
function cmdUI() {
  apiServer.registerCommands({ cmdStart, cmdStop, cmdReload });
  apiServer.startApiServer();
  console.log(c.green(`✓ Web UI 已启动 → http://127.0.0.1:${API_PORT}/`));
}

