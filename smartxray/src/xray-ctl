    req.on('end', async () => {
      let json = {};
      try { if (body) json = JSON.parse(body); } catch {}

      // POST /api/login — 登录认证（无需已认证）
      if (method === 'POST' && url === '/api/login') {
        const adminPwd = getSetting('admin_password', '');
        if (!adminPwd) return apiResponse(res, 200, { ok: true });
        if (json.password !== adminPwd)
          return apiResponse(res, 401, { error: '密码错误' });
        const token = makeAuthToken(adminPwd);
        res.writeHead(200, {
          'Content-Type': 'application/json',
          'Set-Cookie': `_sxtoken=${token}; Path=/; HttpOnly; SameSite=Strict; Max-Age=604800`,
          'Access-Control-Allow-Origin': '*',
        });
        return res.end(JSON.stringify({ ok: true }));
      }

      // POST /api/logout — 清除认证
      if (method === 'POST' && url === '/api/logout') {
        res.writeHead(200, {
          'Content-Type': 'application/json',
          'Set-Cookie': '_sxtoken=; Path=/; HttpOnly; Max-Age=0',
          'Access-Control-Allow-Origin': '*',
        });
        return res.end(JSON.stringify({ ok: true }));
      }

      // 公开 API（不需要管理密码）
      const isPublicApi = url.startsWith('/api/self/') || url === '/api/shared' || url === '/api/public/info' || url === '/api/help';

      // 其他 API 需要认证
      if (!isPublicApi && !isAuthenticated(req)) {
        return apiResponse(res, 401, { error: '未认证，请先登录' });
      }

      // GET /api/status
      if (method === 'GET' && url === '/api/status') {
        return apiResponse(res, 200, {
          running: isRunning(),
          pid:     readPid(),
          users:   db().prepare('SELECT * FROM users ORDER BY port').all(),
          config:  { server_ip: getSetting('server_ip'), log_level: getSetting('log_level') },
        });
      }

      // GET /api/users
      if (method === 'GET' && url === '/api/users') {
        return apiResponse(res, 200, db().prepare('SELECT * FROM users ORDER BY port').all());
      }

      // POST /api/users  { name, protocol, username, password }
      if (method === 'POST' && url === '/api/users') {
        const name     = json.name || `user-${Date.now()}`;
        const protocol = (json.protocol || 'socks').toLowerCase();
        const username = json.username || randStr(8);
        const password = json.password || randStr(12);
        let socksPort, httpPort;
        try {
          const pr = getFixedPortRange();
          socksPort = allocPort(pr.socksMin, pr.socksMax);
          httpPort  = allocPort(pr.httpMin,  pr.httpMax);
        } catch { return apiResponse(res, 500, { error: '端口不足' }); }
        const uuid = newUUID();
        const tag  = `u-${name}-${socksPort}`;
        try {
          db().prepare(
            `INSERT INTO users (name,port,http_port,uuid,protocol,username,password,tag)
             VALUES (?,?,?,?,?,?,?,?)`
          ).run(name, socksPort, httpPort, uuid, protocol, username, password, tag);
          userFirewallOpen(socksPort, httpPort);
          cmdReload();
          return apiResponse(res, 201, db().prepare('SELECT * FROM users WHERE name=?').get(name));
        } catch (e) {
          return apiResponse(res, 400, { error: e.message });
        }
      }

      // DELETE /api/users/:id
      const delMatch = url.match(/^\/api\/users\/(\d+)$/);
      if (method === 'DELETE' && delMatch) {
        const user = db().prepare('SELECT * FROM users WHERE id=?').get(parseInt(delMatch[1]));
        if (!user) return apiResponse(res, 404, { error: 'not found' });
        db().prepare('DELETE FROM users WHERE id=?').run(user.id);
        if (user.name && user.name.startsWith('ss-')) ssFirewallClose(user.port, user.http_port);
        else userFirewallClose(user.port, user.http_port);
        cmdReload();
        return apiResponse(res, 200, { ok: true });
      }

      // PATCH /api/users/:id  { enabled, password, note }
      const patchMatch = url.match(/^\/api\/users\/(\d+)$/);
      if (method === 'PATCH' && patchMatch) {
        const user = db().prepare('SELECT * FROM users WHERE id=?').get(parseInt(patchMatch[1]));
        if (!user) return apiResponse(res, 404, { error: 'not found' });
        if (typeof json.enabled !== 'undefined') {
          db().prepare('UPDATE users SET enabled=? WHERE id=?').run(json.enabled ? 1 : 0, user.id);
          if (json.enabled) userFirewallOpen(user.port, user.http_port);
          else              userFirewallClose(user.port, user.http_port);
        }
        if (json.password) db().prepare('UPDATE users SET password=? WHERE id=?').run(json.password, user.id);
        if (json.note !== undefined) db().prepare('UPDATE users SET note=? WHERE id=?').run(json.note, user.id);
        cmdReload();
        return apiResponse(res, 200, db().prepare('SELECT * FROM users WHERE id=?').get(user.id));
      }

      // POST /api/reload
      if (method === 'POST' && url === '/api/reload') {
        cmdReload();
        return apiResponse(res, 200, { ok: true });
      }

      // POST /api/start
      if (method === 'POST' && url === '/api/start') {
        cmdStart()
          .then(() => apiResponse(res, 200, { running: isRunning() }))
          .catch(e => apiResponse(res, 500, { error: e.message }));
        return;
      }

      // POST /api/stop
      if (method === 'POST' && url === '/api/stop') {
        cmdStop();
        return apiResponse(res, 200, { running: false });
      }

      // GET /api/export
      if (method === 'GET' && url === '/api/export') {
        exportMihomoProxies();
        const yaml = fs.existsSync(MIHOMO_OUT) ? fs.readFileSync(MIHOMO_OUT, 'utf8') : '';
        res.writeHead(200, { 'Content-Type': 'text/plain; charset=utf-8' });
        return res.end(yaml);
      }

      // ── 自助申请 API ──────────────────────────────────────────
      // POST /api/self/request  { email }  →  发送验证码邮件
      if (method === 'POST' && url === '/api/self/request') {
        if (getSetting('selfservice_enabled') !== '1')
          return apiResponse(res, 403, { error: '自助申请功能未开启' });
        const email = json.email;
        if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email))
          return apiResponse(res, 400, { error: '邮箱格式错误' });
        // 清理同邮箱旧验证码
        db().prepare('DELETE FROM verifications WHERE email=? AND used=0').run(email);
        const code      = String(Math.floor(100000 + Math.random() * 900000));
        const expiresAt = new Date(Date.now() + 10 * 60 * 1000).toISOString(); // 10 min
        db().prepare('INSERT INTO verifications(email,code,expires_at) VALUES(?,?,?)').run(email, code, expiresAt);
        const hours = parseInt(getSetting('selfservice_hours', '2')) || 2;
        try {
          await sendMail(email, '【SmartXray】您的验证码',
            `您申请的代理账户验证码：${code}\n\n有效期 10 分钟，账户有效期 ${hours} 小时。\n\n如非本人操作请忽略。`);
          return apiResponse(res, 200, { ok: true });
        } catch (e) {
          return apiResponse(res, 500, { error: '邮件发送失败: ' + e.message });
        }
      }

      // POST /api/self/verify  { email, code }  →  创建临时账户，返回凭据
      if (method === 'POST' && url === '/api/self/verify') {
        if (getSetting('selfservice_enabled') !== '1')
          return apiResponse(res, 403, { error: '自助申请功能未开启' });
        const { email: verEmail, code: verCode } = json;
        if (!verEmail || !verCode)
          return apiResponse(res, 400, { error: '参数缺失' });
        const now = new Date().toISOString();
        const rec = db().prepare(
          'SELECT * FROM verifications WHERE email=? AND code=? AND used=0 AND expires_at>?'
        ).get(verEmail, verCode, now);
        if (!rec) return apiResponse(res, 400, { error: '验证码无效或已过期' });
        db().prepare('UPDATE verifications SET used=1 WHERE id=?').run(rec.id);

        const hours   = parseInt(getSetting('selfservice_hours', '2')) || 2;
        const safeName = verEmail.split('@')[0].replace(/[^a-z0-9]/gi, '').slice(0, 10) || 'user';
        const name    = `ss-${safeName}-${Date.now().toString(36)}`;
        const username = randStr(8);
        const password = randStr(12);
        const expiresAt = new Date(Date.now() + hours * 3600000).toISOString();
        let socksPort, httpPort;
        try {
          const pr = getSsPortRange();
          socksPort = allocPort(pr.socksMin, pr.socksMax);
          httpPort  = allocPort(pr.httpMin,  pr.httpMax);
        } catch (e) { return apiResponse(res, 500, { error: '端口分配失败' }); }
        const uuid = newUUID();
        const tag  = `ss-${name}-${socksPort}`;
        try {
          db().prepare(
            `INSERT INTO users (name,port,http_port,uuid,protocol,username,password,tag,expires_at)
             VALUES (?,?,?,?,'socks',?,?,?,?)`
          ).run(name, socksPort, httpPort, uuid, username, password, tag, expiresAt);
          ssFirewallOpen(socksPort, httpPort);
          cmdReload();
        } catch (e) { return apiResponse(res, 500, { error: '账户创建失败: ' + e.message }); }

        const serverIp = getSetting('server_ip', '');
        const reality  = getRealityConfig();
        const ssSharedSocks = parseInt(getSetting('shared_socks_port', '0')) || 0;
        const ssSharedHttp  = parseInt(getSetting('shared_http_port', '0'))  || 0;
        const result = {
          socks5:     { server: serverIp, port: ssSharedSocks || socksPort, username, password },
          http:       { server: serverIp, port: ssSharedHttp || httpPort,   username, password },
          expires_at: expiresAt,
        };
        if (reality.enabled && reality.publicKey && uuid) {
          const shareLink =
            `vless://${uuid}@${serverIp}:${reality.port}` +
            `?type=tcp&security=reality` +
            `&sni=${encodeURIComponent(reality.serverNames[0] || '')}` +
            `&pbk=${encodeURIComponent(reality.publicKey)}` +
            `&sid=${encodeURIComponent(reality.shortIds[0] || '')}` +
            `&flow=xtls-rprx-vision#xray-${name}`;
          result.vless = {
            server: serverIp, port: reality.port, uuid,
            sni: reality.serverNames[0] || '',
            publicKey: reality.publicKey,
            shareLink,
          };
        }
        return apiResponse(res, 200, result);
      }

      // ── 防火墙配置 API ────────────────────────────────────────
      // GET /api/firewall
      if (method === 'GET' && url === '/api/firewall') {
        const fpr = getFixedPortRange();
        const spr = getSsPortRange();
        return apiResponse(res, 200, {
          mode:               getSetting('extfw_mode', 'none'),
          lightsail_instance: getSetting('lightsail_instance', ''),
          openwrt_host:       getSetting('openwrt_host', ''),
          openwrt_user:       getSetting('openwrt_user', 'root'),
          openwrt_ssh_key:    getSetting('openwrt_ssh_key', ''),
          openwrt_dest_ip:    getSetting('openwrt_dest_ip', ''),
          port_fixed_socks_min: fpr.socksMin, port_fixed_socks_max: fpr.socksMax,
          port_fixed_http_min:  fpr.httpMin,  port_fixed_http_max:  fpr.httpMax,
          port_ss_socks_min:    spr.socksMin, port_ss_socks_max:    spr.socksMax,
          port_ss_http_min:     spr.httpMin,  port_ss_http_max:     spr.httpMax,
        });
      }

      // POST /api/firewall
      if (method === 'POST' && url === '/api/firewall') {
        const fields = ['extfw_mode','lightsail_instance','openwrt_host','openwrt_user','openwrt_ssh_key','openwrt_dest_ip',
          'port_fixed_socks_min','port_fixed_socks_max','port_fixed_http_min','port_fixed_http_max',
          'port_ss_socks_min','port_ss_socks_max','port_ss_http_min','port_ss_http_max'];
        for (const f of fields) {
          if (json[f] !== undefined) setSetting(f, String(json[f]));
        }
        return apiResponse(res, 200, { ok: true });
      }

      // POST /api/firewall/sync
      if (method === 'POST' && url === '/api/firewall/sync') {
        const users   = db().prepare('SELECT * FROM users WHERE enabled=1').all();
        const reality = getRealityConfig();
        for (const u of users) {
          extFwOp('open', u.port);
          if (u.http_port) extFwOp('open', u.http_port);
        }
        if (reality.enabled) extFwOp('open', reality.port);
        return apiResponse(res, 200, { ok: true, synced: users.length });
      }

      // ── 自助申请 API（管理端）─────────────────────────────────
      // GET /api/selfservice — 查看状态
      if (method === 'GET' && url === '/api/selfservice') {
        const fpr = getFixedPortRange();
        const spr = getSsPortRange();
        return apiResponse(res, 200, {
          enabled: getSetting('selfservice_enabled') === '1',
          hours:   parseInt(getSetting('selfservice_hours', '2')) || 2,
          conditions: checkSelfserviceConditions(),
          port_ranges: { fixed: fpr, ss: spr },
        });
      }

      // POST /api/selfservice  { enabled, hours }
      if (method === 'POST' && url === '/api/selfservice') {
        if (typeof json.enabled !== 'undefined') {
          if (json.enabled) {
            const errors = checkSelfserviceConditions();
            if (errors.length) return apiResponse(res, 400, { error: '无法开启: ' + errors.join('; ') });
          }
          setSetting('selfservice_enabled', json.enabled ? '1' : '0');
        }
        if (json.hours !== undefined) {
          const h = parseInt(json.hours);
          if (h >= 1) setSetting('selfservice_hours', String(h));
        }
        return apiResponse(res, 200, { ok: true });
      }

      // ── 设置 API (覆盖原来的只读 status 获取) ────────────────
      // GET /api/settings
      if (method === 'GET' && url === '/api/settings') {
        return apiResponse(res, 200, {
          server_ip:          getSetting('server_ip', ''),
          log_level:          getSetting('log_level', 'warning'),
          upstream_outbounds: getSetting('upstream_outbounds', ''),
          use_upstream:       getSetting('use_upstream', '0') === '1',
        });
      }

      // POST /api/settings
      if (method === 'POST' && url === '/api/settings') {
        if (json.server_ip   !== undefined) setSetting('server_ip', json.server_ip);
        if (json.log_level   !== undefined) setSetting('log_level', json.log_level);
        if (json.use_upstream !== undefined) setSetting('use_upstream', json.use_upstream ? '1' : '0');
        if (json.upstream_outbounds !== undefined) {
          if (json.upstream_outbounds) {
            try { JSON.parse(json.upstream_outbounds); }
            catch (e) { return apiResponse(res, 400, { error: 'upstream_outbounds JSON 格式错误: ' + e.message }); }
          }
          setSetting('upstream_outbounds', json.upstream_outbounds);
        }
        cmdReload();
        return apiResponse(res, 200, { ok: true });
      }

      // ── 原始配置 API ──────────────────────────────────────────
      // GET /api/config/raw
      if (method === 'GET' && url === '/api/config/raw') {
        const content = fs.existsSync(XRAY_CONF) ? fs.readFileSync(XRAY_CONF, 'utf8') : '{}';
        return apiResponse(res, 200, { content });
      }

      // POST /api/config/raw
      if (method === 'POST' && url === '/api/config/raw') {
        const content = json.content;
        if (!content) return apiResponse(res, 400, { error: '缺少 content 字段' });
        try {
          JSON.parse(content);  // 验证 JSON 格式
          fs.writeFileSync(XRAY_CONF, content);
          cmdReload();
          return apiResponse(res, 200, { ok: true });
        } catch (e) {
          return apiResponse(res, 400, { error: 'JSON 格式错误: ' + e.message });
        }
      }

      // GET /api/help — 返回帮助 markdown 内容
      if (method === 'GET' && url === '/api/help') {
        const helpFile = path.join(uiDir, 'help.md');
        const md = fs.existsSync(helpFile) ? fs.readFileSync(helpFile, 'utf8') : '';
        res.writeHead(200, { 'Content-Type': 'text/plain; charset=utf-8', 'Access-Control-Allow-Origin': '*' });
        return res.end(md);
      }

      // GET /api/shared — 返回共享端口信息（自助页面等可读取）
      if (method === 'GET' && url === '/api/shared') {
        return apiResponse(res, 200, {
          shared_socks_port: parseInt(getSetting('shared_socks_port', '0')) || 0,
          shared_http_port:  parseInt(getSetting('shared_http_port', '0'))  || 0,
          server_ip: getSetting('server_ip', ''),
        });
      }

      // GET /api/public/info — 公开信息（门户页配置生成器使用，无需认证）
      if (method === 'GET' && url === '/api/public/info') {
        const reality = getRealityConfig();
        const result = { reality_enabled: reality.enabled };
        if (reality.enabled) {
          result.reality_port   = reality.port;
          result.reality_sni    = reality.serverNames[0] || '';
          result.reality_pubkey = reality.publicKey || '';
          result.reality_sid    = reality.shortIds[0] || '';
        }
        return apiResponse(res, 200, result);
      }

      // ── SMTP 配置 API ─────────────────────────────────────────
      // GET /api/smtp
      if (method === 'GET' && url === '/api/smtp') {
        return apiResponse(res, 200, {
          smtp_host:   getSetting('smtp_host', ''),
          smtp_port:   parseInt(getSetting('smtp_port', '587')) || 587,
          smtp_secure: getSetting('smtp_secure', '0') === '1',
          smtp_user:   getSetting('smtp_user', ''),
          smtp_pass:   getSetting('smtp_pass', '') ? '••••••' : '',
          smtp_from:   getSetting('smtp_from', ''),
        });
      }

      // POST /api/smtp  — 保存 SMTP 配置
      if (method === 'POST' && url === '/api/smtp') {
        if (json.smtp_host !== undefined) setSetting('smtp_host', json.smtp_host);
        if (json.smtp_port !== undefined) setSetting('smtp_port', String(json.smtp_port));
        if (json.smtp_secure !== undefined) setSetting('smtp_secure', json.smtp_secure ? '1' : '0');
        if (json.smtp_user !== undefined) setSetting('smtp_user', json.smtp_user);
        if (json.smtp_pass !== undefined && json.smtp_pass !== '••••••') setSetting('smtp_pass', json.smtp_pass);
        if (json.smtp_from !== undefined) setSetting('smtp_from', json.smtp_from);
        return apiResponse(res, 200, { ok: true });
      }

      // POST /api/smtp/test  — 发送测试邮件
      if (method === 'POST' && url === '/api/smtp/test') {
        const testTo = json.to;
        if (!testTo) return apiResponse(res, 400, { error: '请填写测试收件地址' });
        try {
          await sendMail(testTo, '【SmartXray】SMTP 测试', '这是一封测试邮件，如果你收到说明 SMTP 配置正确。\n\n— SmartXray');
          return apiResponse(res, 200, { ok: true });
        } catch (e) {
          return apiResponse(res, 500, { error: 'SMTP 发送失败: ' + e.message });
        }
      }

      res.writeHead(404); res.end();
    });
  });

  server.on('error', e => {
    if (e.code === 'EADDRINUSE') console.log(c.dim(`  API server 已在运行 (port ${API_PORT})`));
    else console.log(c.red(`  API server 错误: ${e.message}`));
  });
  server.listen(API_PORT, '0.0.0.0', () => {
    _apiServerRunning = true;
    console.log(c.dim(`  Web UI: http://0.0.0.0:${API_PORT}/  (or http://<server-ip>:${API_PORT}/)`));
    // 定期清理过期账户和验证码（每 60 秒）
    cleanupExpired();
    setInterval(cleanupExpired, 60 * 1000);
  });
}

// ─── 命令：autostart ─────────────────────────────────────────
function cmdAutostart(args) {
  const sub = args[0];
  if (sub === 'on') {
    try { autostartAdapter.enable(); }
    catch (e) { console.log(c.red(`✗ ${e.message}`)); }
    return;
  }
  if (sub === 'off') {
    autostartAdapter.disable();
    return;
  }
  const enabled = autostartAdapter.isEnabled();
  console.log(`开机自启: ${enabled ? c.green('已启用') : c.dim('已禁用')}`);
  console.log(c.dim('  修改: xray-ctl autostart on|off'));
}

// ─── 命令：upgrade（自升级）─────────────────────────────────
async function cmdUpgrade() {
  console.log(c.bold('\n── xray-ctl 自升级 ─────────────────────────────'));
  console.log(c.dim(`  来源: GitHub Release (${GITHUB_REPO})\n`));

  process.stdout.write('  查询最新版本... ');
  let latest, latestTag;
  try {
    const out = run(`curl -sf --max-time 10 "https://api.github.com/repos/${GITHUB_REPO}/releases?per_page=50"`);
    if (!out) { console.log(c.red('无响应，检查网络')); return; }
    const releases = JSON.parse(out);
    const parseVF = v => v.split('.').map(Number);
    const cmpVF = (a, b) => { for (let i = 0; i < 3; i++) { if (a[i] !== b[i]) return a[i] - b[i]; } return 0; };
    let bestVer = null, bestTag = null;
    for (const r of releases) {
      if (!r.tag_name || !r.tag_name.startsWith('smartxray-v')) continue;
      const ver = r.tag_name.replace('smartxray-v', '');
      if (!bestVer || cmpVF(parseVF(ver), parseVF(bestVer)) > 0) { bestVer = ver; bestTag = r.tag_name; }
    }
    if (!bestVer) { console.log(c.yellow('未找到 smartxray release，请先发布')); return; }
    latestTag = bestTag;
    latest    = bestVer;
  } catch (e) { console.log(c.red(`失败: ${e.message}`)); return; }
  console.log(`最新 ${c.green('v' + latest)}`);

  const parseVer = v => v.split('.').map(Number);
  const [ra, rb, rc] = parseVer(latest);
  const [la, lb, lc] = parseVer(VERSION);
  const isNewer = ra > la || (ra === la && rb > lb) || (ra === la && rb === lb && rc > lc);
  if (!isNewer) {
    console.log(latest === VERSION ? c.green('  ✓ 已是最新版本') : c.yellow(`  ⚠ 远端 v${latest} 比当前 v${VERSION} 旧，跳过`));
    return;
  }

  // bundle 模式：下载 xray-ctl-bundle-{ver}.tar.gz 并更新 /usr/local/lib/smartxray/
  const LIB_DIR   = '/usr/local/lib/smartxray';
  const assetName = `xray-ctl-bundle-${latest}.tar.gz`;
  const url       = `https://github.com/${GITHUB_REPO}/releases/download/${latestTag}/${assetName}`;
  const tmpTar    = path.join(os.tmpdir(), assetName);
  const tmpExtDir = path.join(os.tmpdir(), `xray-ctl-bundle-${latest}`);

  process.stdout.write(`  下载 ${assetName}... `);
  try {
    execSync(`curl -fsSL --max-time 60 -o "${tmpTar}" "${url}"`, { stdio: 'pipe' });
  } catch (e) { console.log(c.red('失败')); console.log(c.dim(`  URL: ${url}`)); return; }
  console.log('done');

  try {
    fs.mkdirSync(tmpExtDir, { recursive: true });
    execSync(`tar xzf "${tmpTar}" -C "${tmpExtDir}"`, { stdio: 'pipe' });
    fs.rmSync(tmpTar, { force: true });
  } catch (e) { console.log(c.red(`✗ 解压失败: ${e.message}`)); return; }

  // 备份旧 bundle 目录
  const bak = `${LIB_DIR}.bak-v${VERSION}`;
  try {
    if (fs.existsSync(LIB_DIR)) run(`sudo cp -r "${LIB_DIR}" "${bak}"`);
    run(`sudo sh -c 'mkdir -p "${LIB_DIR}" && cp -r "${tmpExtDir}/." "${LIB_DIR}/"'`);
    fs.rmSync(tmpExtDir, { recursive: true, force: true });
  } catch (e) { console.log(c.red(`✗ 替换失败: ${e.message}`)); return; }

  console.log(c.bold('\n── 升级结果 ──────────────────────────────────'));
  console.log(c.green('  ✓ xray-ctl 升级成功'));
  console.log(`     ${c.yellow('v' + VERSION)} → ${c.green('v' + latest)}`);
  console.log(c.dim(`  备份: ${bak}`));
}

