    enable()     { run('sudo rc-update add smartxray default 2>/dev/null || true'); console.log(c.green('✓ 已启用开机自启 (rc-update add smartxray default)')); },
    disable()    { run('sudo rc-update del smartxray default 2>/dev/null || true'); console.log(c.dim('✓ 已禁用开机自启')); },
  },
  freebsd: {
    isEnabled()  { return run('sysrc -n smartxray_enable 2>/dev/null').trim().toUpperCase() === 'YES'; },
    enable()     { run('sudo sysrc smartxray_enable=YES 2>/dev/null || true'); console.log(c.green('✓ 已启用开机自启 (sysrc smartxray_enable=YES)')); },
    disable()    { run('sudo sysrc smartxray_enable=NO 2>/dev/null || true'); console.log(c.dim('✓ 已禁用开机自启')); },
  },
};
const autostartAdapter = AUTOSTART[detectPlatform()] || AUTOSTART.linux;

function randStr(len = 16) {
  return crypto.randomBytes(len).toString('base64url').slice(0, len);
}

function randHex(n = 8) {
  return crypto.randomBytes(Math.ceil(n / 2)).toString('hex').slice(0, n);
}

function newUUID() {
  return crypto.randomUUID ? crypto.randomUUID() : randHex(8)+'-'+randHex(4)+'-4'+randHex(3)+'-'+randHex(4)+'-'+randHex(12);
}

function ensureDir(dir) {
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
}

function fmtDate(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('zh-CN', { hour12: false });
}

// ─── SQLite 初始化 ───────────────────────────────────────────
let _db = null;
function db() {
  if (_db) return _db;
  try {
    const Database = require(path.join(DATA_DIR, 'node_modules', 'better-sqlite3'));
    ensureDir(DATA_DIR);
    _db = new Database(DB_FILE);
    _db.exec(`
      CREATE TABLE IF NOT EXISTS users (
        id         INTEGER PRIMARY KEY AUTOINCREMENT,
        name       TEXT    NOT NULL UNIQUE,
        port       INTEGER NOT NULL UNIQUE,
        http_port  INTEGER UNIQUE,
        uuid       TEXT,
        protocol   TEXT    NOT NULL DEFAULT 'socks',
        username   TEXT    NOT NULL,
        password   TEXT    NOT NULL,
        tag        TEXT    NOT NULL UNIQUE,
        enabled    INTEGER NOT NULL DEFAULT 1,
        expires_at TEXT    DEFAULT NULL,
        note       TEXT    DEFAULT '',
        created_at TEXT    NOT NULL DEFAULT (datetime('now'))
      );
      CREATE TABLE IF NOT EXISTS settings (
        key   TEXT PRIMARY KEY,
        value TEXT
      );
      CREATE TABLE IF NOT EXISTS verifications (
        id         INTEGER PRIMARY KEY AUTOINCREMENT,
        email      TEXT    NOT NULL,
        code       TEXT    NOT NULL,
        created_at TEXT    NOT NULL DEFAULT (datetime('now')),
        expires_at TEXT    NOT NULL,
        used       INTEGER NOT NULL DEFAULT 0
      );
    `);
    // 旧库 schema 迁移
    const cols = _db.prepare('PRAGMA table_info(users)').all().map(r => r.name);
    if (!cols.includes('http_port'))  _db.exec('ALTER TABLE users ADD COLUMN http_port  INTEGER DEFAULT NULL');
    if (!cols.includes('uuid'))       _db.exec('ALTER TABLE users ADD COLUMN uuid       TEXT    DEFAULT NULL');
    if (!cols.includes('expires_at')) _db.exec('ALTER TABLE users ADD COLUMN expires_at TEXT    DEFAULT NULL');
    return _db;
  } catch (e) {
    console.log(c.red(`✗ SQLite 初始化失败: ${e.message}`));
    console.log(c.dim('  请先安装依赖: cd smartxray && npm install'));
    process.exit(1);
  }
}

function getSetting(key, def = '') {
  const row = db().prepare('SELECT value FROM settings WHERE key=?').get(key);
  return row ? row.value : def;
}

function setSetting(key, value) {
  db().prepare('INSERT OR REPLACE INTO settings(key,value) VALUES(?,?)').run(key, String(value));
}

// ─── Xray 进程管理 ───────────────────────────────────────────
const OPENRC_PID = '/run/smartxray.pid';  // OpenRC 管理时写入的 PID 文件

function readPid() {
  // 依次尝试 xray-ctl 自身 PID 文件和 OpenRC PID 文件，返回实际在运行的 PID
  for (const f of [PID_FILE, OPENRC_PID]) {
    try {
      const pid = parseInt(fs.readFileSync(f, 'utf8').trim(), 10);
      if (pid) {
        try {
          process.kill(pid, 0);          // 仅探测是否存在，不发实际信号
          if (f !== PID_FILE) writePidFiles(pid);  // 从 fallback 读到时同步写回
          return pid;
        } catch { /**/ }
      }
    } catch { /**/ }
  }
  return null;
}

function writePidFiles(pid) {
  ensureDir(DATA_DIR);
  fs.writeFileSync(PID_FILE, String(pid));
  try { fs.writeFileSync(OPENRC_PID, String(pid)); } catch { /**/ }
}

function writePid(pid) { writePidFiles(pid); }

function isRunning() {
  return readPid() !== null;  // readPid() 已含存活检查
}

// ─── 端口分配 ────────────────────────────────────────────────
function allocPort(min, max) {
  const used = new Set(
    db().prepare('SELECT port FROM users').all().map(r => r.port)
      .concat(db().prepare('SELECT http_port FROM users WHERE http_port IS NOT NULL').all().map(r => r.http_port))
  );
  let p, tries = 0;
  do { p = min + Math.floor(Math.random() * (max - min + 1)); tries++; }
  while (used.has(p) && tries < 2000);
  if (used.has(p)) throw new Error('端口耗尽');
  return p;
}

// ─── Reality 配置读取 ────────────────────────────────────────
function getRealityConfig() {
  return {
    enabled:     getSetting('reality_enabled') === '1',
    port:        parseInt(getSetting('reality_port', '8443')) || 8443,
    privateKey:  getSetting('reality_private_key'),
    publicKey:   getSetting('reality_public_key'),
    shortIds:    getSetting('reality_short_ids', '').split(',').filter(Boolean),
    dest:        getSetting('reality_dest', 'www.microsoft.com:443'),
    serverNames: getSetting('reality_server_names', 'www.microsoft.com').split(',').filter(Boolean),
  };
}

// ─── Xray 配置生成 ───────────────────────────────────────────
function buildConfig() {
  const users    = db().prepare('SELECT * FROM users WHERE enabled=1 ORDER BY port').all();
  const serverIp = getSetting('server_ip', '0.0.0.0');
  const reality  = getRealityConfig();
  const listen   = '0.0.0.0'; // 服务端始终监听所有接口
  const inbounds = [];

  // ── VLESS + XTLS-Reality 共享入站（最严格防审查配置）──────
  // 所有用户共用同一端口，用 UUID 区分身份；Vision flow 防流量特征
  if (reality.enabled && reality.privateKey) {
    const vlessClients = users.filter(u => u.uuid).map(u => ({
      id:   u.uuid,
      flow: 'xtls-rprx-vision',   // XTLS Vision：最强流量混淆
    }));
    if (vlessClients.length) {
      inbounds.push({
        tag:      'vless-reality',
        port:     reality.port,
        listen,
        protocol: 'vless',
        settings: { clients: vlessClients, decryption: 'none' },
        streamSettings: {
          network:  'tcp',
          security: 'reality',
          realitySettings: {
            show:        false,
            dest:        reality.dest,         // 伪装目标（流量特征与目标站一致）
            xver:        0,
            serverNames: reality.serverNames,  // SNI 白名单
            privateKey:  reality.privateKey,
            shortIds:    reality.shortIds.length ? reality.shortIds : [''],
          },
        },
        sniffing: { enabled: true, destOverride: ['http', 'tls', 'quic'], routeOnly: false },
      });
    }
  }

  // ── 每用户独立 SOCKS5 + HTTP 入站（账密认证）──────────────
  for (const u of users) {
    // SOCKS5（支持 UDP，账密认证）
    inbounds.push({
      tag:      u.tag,
      port:     u.port,
      listen,
      protocol: 'socks',
      settings: { auth: 'password', accounts: [{ user: u.username, pass: u.password }], udp: true },
      sniffing: { enabled: true, destOverride: ['http', 'tls'] },
    });
    // HTTP 代理（账密认证）
    if (u.http_port) {
      inbounds.push({
        tag:      u.tag + '-http',
        port:     u.http_port,
        listen,
        protocol: 'http',
        settings: { accounts: [{ user: u.username, pass: u.password }], allowTransparent: false },
      });
    }
  }

  // API inbound（本地管理用）
  inbounds.push({
    tag: 'api', port: XRAY_API_PORT, listen: '127.0.0.1',
    protocol: 'dokodemo-door', settings: { address: '127.0.0.1' },
  });

  const config = {
    log:    { loglevel: getSetting('log_level', 'warning'), access: LOG_FILE, error: LOG_FILE },
    api:    { tag: 'api', services: ['HandlerService', 'StatsService'] },
    stats:  {},
    policy: { system: { statsInboundUplink: true, statsInboundDownlink: true } },
    routing: {
      domainStrategy: 'IPIfNonMatch',
      rules: [
        { type: 'field', inboundTag: ['api'], outboundTag: 'direct' },
        { type: 'field', ip: ['geoip:private'], outboundTag: 'direct' },
      ],
    },
    inbounds,
    outbounds: [
      { tag: 'direct', protocol: 'freedom',   settings: {} },
      { tag: 'block',  protocol: 'blackhole',  settings: {} },
    ],
  };

  // 注入上游出站（upstream outbounds）
  const upstreamJson = getSetting('upstream_outbounds', '');
  let upstreamOutbounds = [];
  if (upstreamJson) {
    try {
      upstreamOutbounds = JSON.parse(upstreamJson);
      if (Array.isArray(upstreamOutbounds) && upstreamOutbounds.length) {
        config.outbounds.push(...upstreamOutbounds);
        // 若启用上游转发，追加默认路由规则（私有 IP 直连，其余走第一个上游）
        if (getSetting('use_upstream', '0') === '1') {
          config.routing.rules.push({
            type: 'field', network: 'tcp,udp',
            outboundTag: upstreamOutbounds[0].tag,
          });
        }
      }
    } catch {
      // JSON 解析失败时忽略，回退到 direct
    }
  }

  // ── merge_inbounds 模式：只替换 inbounds，保留 outbounds/routing/balancers/observatory ──
  // 适用于现有手工维护的 xray 配置（多 outbound + leastPing balancer + geosite 路由等）
  const mergeMode = getSetting('merge_inbounds', '0') === '1' && fs.existsSync(XRAY_CONF);
  if (mergeMode) {
    let existing = {};
    try { existing = JSON.parse(fs.readFileSync(XRAY_CONF, 'utf8')); } catch { /**/ }
    // 拆分现有路由规则：
    //   无 inboundTag → 直接保留（domain/ip 直连规则等，顺序不变）
    //   有 inboundTag + balancerTag → 去掉 inboundTag 变为全流量路由（追加末尾）
    //   有 inboundTag + outboundTag (非 api) → 过时标签，丢弃
    const preservedRules = [];
    const catchAllRules  = [];
    for (const r of (existing.routing?.rules || [])) {
      if (!r.inboundTag) {
        preservedRules.push(r);
      } else if (r.balancerTag) {
        // eslint-disable-next-line no-unused-vars
        const { inboundTag, ...rest } = r;
        catchAllRules.push(rest);
      }
      // else: 过时的 inboundTag+outboundTag 规则 → 丢弃
    }
    const merged = {
      log:    { loglevel: getSetting('log_level', 'warning'), access: LOG_FILE, error: LOG_FILE },
      api:    { tag: 'api', services: ['HandlerService', 'StatsService'] },
      stats:  {},
      policy: { system: { statsInboundUplink: true, statsInboundDownlink: true } },
      routing: {
        domainStrategy: existing.routing?.domainStrategy || 'IPIfNonMatch',
        rules: [
          { type: 'field', inboundTag: ['api'], outboundTag: 'direct' },
          ...preservedRules,   // geoip:private、geosite:cn 等直连规则
          ...catchAllRules,    // 去掉旧 inboundTag 的 balancer 全流量规则
        ],
      },
      inbounds,
      outbounds: existing.outbounds?.length
        ? existing.outbounds
        : [{ tag: 'direct', protocol: 'freedom', settings: {} }, { tag: 'block', protocol: 'blackhole', settings: {} }],
    };
    if (existing.balancers?.length)  merged.balancers        = existing.balancers;
    if (existing.observatory)        merged.observatory       = existing.observatory;
    if (existing.burstObservatory)   merged.burstObservatory  = existing.burstObservatory;
    ensureDir(path.dirname(XRAY_CONF));
    fs.writeFileSync(XRAY_CONF, JSON.stringify(merged, null, 2));
    return merged;
  }

  ensureDir(path.dirname(XRAY_CONF));
  fs.writeFileSync(XRAY_CONF, JSON.stringify(config, null, 2));
  return config;
}

// ─── 导出 mihomo proxies 片段 ────────────────────────────────
function exportMihomoProxies() {
  const users   = db().prepare('SELECT * FROM users WHERE enabled=1 ORDER BY port').all();
  const reality = getRealityConfig();
  if (!users.length) { fs.writeFileSync(MIHOMO_OUT, '# no proxies\n'); return; }
  const ip    = getSetting('server_ip', '127.0.0.1');
  const lines = ['proxies:'];
  for (const u of users) {
    // VLESS + Reality
    if (reality.enabled && reality.publicKey && u.uuid) {
      lines.push(`  - name: "${u.name}-vless"`);
      lines.push(`    type: vless`);
      lines.push(`    server: ${ip}`);
      lines.push(`    port: ${reality.port}`);
      lines.push(`    uuid: ${u.uuid}`);
      lines.push(`    flow: xtls-rprx-vision`);
      lines.push(`    tls: true`);
      lines.push(`    servername: ${reality.serverNames[0] || 'www.microsoft.com'}`);
      lines.push(`    reality-opts:`);
      lines.push(`      public-key: ${reality.publicKey}`);
      lines.push(`      short-id: ${reality.shortIds[0] || ''}`);
      lines.push(`    network: tcp`);
    }
    // SOCKS5
    lines.push(`  - name: "${u.name}-socks5"`);
    lines.push(`    type: socks5`);
    lines.push(`    server: ${ip}`);
    lines.push(`    port: ${u.port}`);
    lines.push(`    username: ${u.username}`);
    lines.push(`    password: ${u.password}`);
    lines.push(`    udp: true`);
    // HTTP
    if (u.http_port) {
      lines.push(`  - name: "${u.name}-http"`);
      lines.push(`    type: http`);
      lines.push(`    server: ${ip}`);
      lines.push(`    port: ${u.http_port}`);
      lines.push(`    username: ${u.username}`);
      lines.push(`    password: ${u.password}`);
    }
  }
  fs.writeFileSync(MIHOMO_OUT, lines.join('\n') + '\n');
  console.log(c.dim(`  mihomo 配置已导出 → ${MIHOMO_OUT}`));
}

// ─── 防火墙端口管理 ──────────────────────────────────────────
function fwOp(action, port) {
  if (!port) return;
  const ufw   = run('which ufw 2>/dev/null');
  const fwcmd = run('which firewall-cmd 2>/dev/null');
  const ipt   = run('which iptables 2>/dev/null');
  if (ufw) {
    if (action === 'open') {
      run(`sudo ufw allow ${port}/tcp 2>/dev/null`);
      run(`sudo ufw allow ${port}/udp 2>/dev/null`);
    } else {
      run(`sudo ufw delete allow ${port}/tcp 2>/dev/null`);
      run(`sudo ufw delete allow ${port}/udp 2>/dev/null`);
    }
  } else if (fwcmd) {
    if (action === 'open') {
      run(`sudo firewall-cmd --permanent --add-port=${port}/tcp 2>/dev/null`);
      run(`sudo firewall-cmd --permanent --add-port=${port}/udp 2>/dev/null`);
    } else {
      run(`sudo firewall-cmd --permanent --remove-port=${port}/tcp 2>/dev/null`);
      run(`sudo firewall-cmd --permanent --remove-port=${port}/udp 2>/dev/null`);
    }
    run('sudo firewall-cmd --reload 2>/dev/null');
  } else if (ipt) {
    const flag = action === 'open' ? '-I' : '-D';
    run(`sudo iptables ${flag} INPUT -p tcp --dport ${port} -j ACCEPT 2>/dev/null`);
    run(`sudo iptables ${flag} INPUT -p udp --dport ${port} -j ACCEPT 2>/dev/null`);
  } else if (process.platform === 'darwin') {
    if (action === 'open') {
      run(`printf 'pass in proto tcp to any port ${port}\npass in proto udp to any port ${port}\n' | sudo pfctl -a 'com.xray/p${port}' -f - 2>/dev/null`);
    } else {
      run(`sudo pfctl -a 'com.xray/p${port}' -F all 2>/dev/null`);
    }
  }
}

// ─── 外部防火墙：AWS Lightsail 安全组 ────────────────────────
function lightsailFw(action, port) {
  const instance = getSetting('lightsail_instance', '');
  if (!instance) return;
  const op = action === 'open' ? 'open-instance-public-ports' : 'close-instance-public-ports';
  for (const proto of ['TCP', 'UDP']) {
    run(`aws lightsail ${op} --instance-name "${instance}" --port-info fromPort=${port},toPort=${port},protocol=${proto} 2>/dev/null || true`);
  }
}

// ─── 外部防火墙：OpenWrt DNAT 端口转发 ─────────────────────
function openwrtFw(action, port) {
  const host    = getSetting('openwrt_host', '');
  const user    = getSetting('openwrt_user', 'root');
  const keyPath = getSetting('openwrt_ssh_key', '');
  const destIp  = getSetting('openwrt_dest_ip', '');
  if (!host || !destIp) return;
  const keyOpt = keyPath ? `-i "${keyPath}"` : '';
  const ssh    = `ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 ${keyOpt} "${user}@${host}"`;
  for (const proto of ['tcp', 'udp']) {
    const name = `smartxray_${port}_${proto}`;
    if (action === 'open') {
      const cmd = [
        `uci add firewall redirect`,
        `uci set firewall.@redirect[-1].name='${name}'`,
        `uci set firewall.@redirect[-1].src='wan'`,
        `uci set firewall.@redirect[-1].dest='lan'`,
        `uci set firewall.@redirect[-1].proto='${proto}'`,
        `uci set firewall.@redirect[-1].src_dport='${port}'`,
        `uci set firewall.@redirect[-1].dest_ip='${destIp}'`,
        `uci set firewall.@redirect[-1].dest_port='${port}'`,
        `uci set firewall.@redirect[-1].target='DNAT'`,
        `uci commit firewall && /etc/init.d/firewall reload`,
      ].join(' && ');
      run(`${ssh} '${cmd}' 2>/dev/null || true`);
    } else {
      // 按名称逐索引查找并删除
      const del = `i=0; while uci get firewall.@redirect[$i] >/dev/null 2>&1; do n=$(uci get firewall.@redirect[$i].name 2>/dev/null); if [ "$n" = "${name}" ]; then uci delete firewall.@redirect[$i] && uci commit firewall && /etc/init.d/firewall reload; break; fi; i=$((i+1)); done`;
      run(`${ssh} '${del}' 2>/dev/null || true`);
    }
  }
}

function extFwOp(action, port) {
  const mode = getSetting('extfw_mode', 'none');
  if (mode === 'lightsail') lightsailFw(action, port);
  else if (mode === 'openwrt') openwrtFw(action, port);
}

function firewallOpen(port)  { fwOp('open',  port); extFwOp('open',  port); }
function firewallClose(port) { fwOp('close', port); extFwOp('close', port); }

// ─── 命令：status ────────────────────────────────────────────
function cmdStatus() {
  const running   = isRunning();
  const pid       = readPid();
  const ver       = running ? run(`${BIN} version 2>/dev/null | head -1`) : '';
  const users     = db().prepare('SELECT * FROM users ORDER BY port').all();
  const reality   = getRealityConfig();
