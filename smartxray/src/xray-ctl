// ─── 发送验证邮件 ───────────────────────────────────────️
async function sendMail(to, subject, text) {
  const host = getSetting('smtp_host');
  if (!host) throw new Error('SMTP 未配置，请在设置页面配置邮件服务器');
  let nodemailer;
  try { nodemailer = require('nodemailer'); }
  catch { throw new Error('nodemailer 未安装: cd smartxray && npm install'); }
  const port   = parseInt(getSetting('smtp_port', '587'));
  const secure = getSetting('smtp_secure') === '1';
  const user   = getSetting('smtp_user');
  const pass   = getSetting('smtp_pass');
  const opts   = { host, port, secure };
  if (user && pass) opts.auth = { user, pass };
  const transporter = nodemailer.createTransport(opts);
  await transporter.sendMail({
    from:    getSetting('smtp_from') || user,
    to,
    subject,
    text,
  });
}

// ─── 过期账户时隔清理 ────────────────────────────────────
function cleanupExpired() {
  const now     = new Date().toISOString();
  const expired = db().prepare('SELECT * FROM users WHERE expires_at IS NOT NULL AND expires_at < ?').all(now);
  if (expired.length) {
    for (const u of expired) {
      db().prepare('DELETE FROM users WHERE id=?').run(u.id);
      // 自助用户(ss-)始终关闭独占端口，固定用户走常规逻辑
      if (u.name && u.name.startsWith('ss-')) ssFirewallClose(u.port, u.http_port);
      else userFirewallClose(u.port, u.http_port);
    }
    console.log(c.dim(`[cleanup] 删除 ${expired.length} 个过期账户`));
    cmdReload();
  }
  // 清理过期验证码
  db().prepare('DELETE FROM verifications WHERE expires_at < ?').run(now);
}

