    enable()     { run('sudo sysrc smartxray_enable=YES 2>/dev/null || true'); console.log(c.green('✓ 已启用开机自启 (sysrc smartxray_enable=YES)')); },
    disable()    { run('sudo sysrc smartxray_enable=NO 2>/dev/null || true'); console.log(c.dim('✓ 已禁用开机自启')); },
  },
};
const autostartAdapter = AUTOSTART[detectPlatform()] || AUTOSTART.linux;

function randStr(len = 16) {
  return crypto.randomBytes(len).toString('base64url').slice(0, len);
}

function randHex(n = 8) {
  return crypto.randomBytes(Math.ceil(n / 2)).toString('hex').slice(0, n);
}

function newUUID() {
  return crypto.randomUUID ? crypto.randomUUID() : randHex(8)+'-'+randHex(4)+'-4'+randHex(3)+'-'+randHex(4)+'-'+randHex(12);
}

function ensureDir(dir) {
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
}

function fmtDate(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('zh-CN', { hour12: false });
}

// ─── SQLite 初始化 ───────────────────────────────────────────
let _db = null;
function db() {
  if (_db) return _db;
  try {
    const { Database } = require('node-sqlite3-wasm');
    ensureDir(DATA_DIR);
    // node-sqlite3-wasm 会创建 .lock 目录；若上次进程未能清理则残留，强制清除后再开
    const lockDir = DB_FILE + '.lock';
    if (fs.existsSync(lockDir)) {
      try { fs.rmSync(lockDir, { recursive: true, force: true }); } catch {}
    }
    _db = new Database(DB_FILE);
    _db.exec(`
      CREATE TABLE IF NOT EXISTS users (
        id         INTEGER PRIMARY KEY AUTOINCREMENT,
        name       TEXT    NOT NULL UNIQUE,
        port       INTEGER NOT NULL UNIQUE,
        http_port  INTEGER UNIQUE,
        uuid       TEXT,
        protocol   TEXT    NOT NULL DEFAULT 'socks',
        username   TEXT    NOT NULL,
        password   TEXT    NOT NULL,
        tag        TEXT    NOT NULL UNIQUE,
        enabled    INTEGER NOT NULL DEFAULT 1,
        expires_at TEXT    DEFAULT NULL,
        note       TEXT    DEFAULT '',
        created_at TEXT    NOT NULL DEFAULT (datetime('now'))
      );
      CREATE TABLE IF NOT EXISTS settings (
        key   TEXT PRIMARY KEY,
        value TEXT
      );
      CREATE TABLE IF NOT EXISTS verifications (
        id         INTEGER PRIMARY KEY AUTOINCREMENT,
        email      TEXT    NOT NULL,
        code       TEXT    NOT NULL,
        created_at TEXT    NOT NULL DEFAULT (datetime('now')),
        expires_at TEXT    NOT NULL,
        used       INTEGER NOT NULL DEFAULT 0
      );
    `);
    // 旧库 schema 迁移
    const cols = _db.prepare('PRAGMA table_info(users)').all().map(r => r.name);
    if (!cols.includes('http_port'))  _db.exec('ALTER TABLE users ADD COLUMN http_port  INTEGER DEFAULT NULL');
    if (!cols.includes('uuid'))       _db.exec('ALTER TABLE users ADD COLUMN uuid       TEXT    DEFAULT NULL');
    if (!cols.includes('expires_at')) _db.exec('ALTER TABLE users ADD COLUMN expires_at TEXT    DEFAULT NULL');
    // node-sqlite3-wasm 需要显式 close() 才能释放锁目录
    process.on('exit', () => { try { _db.close(); } catch {} });

    // node-sqlite3-wasm 的 Statement.run/get/all 只接受单个 values 参数（数组或单值），
    // 而 better-sqlite3 接受 spread 参数。通过 monkeypatch prepare() 统一适配，
    // 同时自动 finalize() 避免内存泄漏。
    const _origPrepare = _db.prepare.bind(_db);
    _db.prepare = (sql) => {
      const _wrap = (method) => (...args) => {
        const s = _origPrepare(sql);
        try {
          // 0 args → undefined (positional无参), 1 arg → 直接传, 多 args → 转数组
          return method === 'run'
            ? s.run(args.length <= 1 ? args[0] : args)
            : method === 'get'
              ? s.get(args.length <= 1 ? args[0] : args)
              : s.all(args.length <= 1 ? args[0] : args);
        } finally { s.finalize(); }
      };
      return { run: _wrap('run'), get: _wrap('get'), all: _wrap('all') };
    };

    return _db;
  } catch (e) {
    console.log(c.red(`✗ SQLite 初始化失败: ${e.message}`));
    console.log(c.dim('  请重新安装: node scripts/install.js'));
    process.exit(1);
  }
}

function getSetting(key, def = '') {
  const row = db().prepare('SELECT value FROM settings WHERE key=?').get(key);
  return row ? row.value : def;
}

function setSetting(key, value) {
  db().prepare('INSERT OR REPLACE INTO settings(key,value) VALUES(?,?)').run(key, String(value));
}

// ─── Xray 进程管理 ───────────────────────────────────────────
const OPENRC_PID = '/run/smartxray.pid';  // OpenRC 管理时写入的 PID 文件

function readPid() {
  // 依次尝试 xray-ctl 自身 PID 文件和 OpenRC PID 文件，返回实际在运行的 PID
  for (const f of [PID_FILE, OPENRC_PID]) {
    try {
      const pid = parseInt(fs.readFileSync(f, 'utf8').trim(), 10);
      if (pid) {
        try {
          process.kill(pid, 0);          // 仅探测是否存在，不发实际信号
          if (f !== PID_FILE) writePidFiles(pid);  // 从 fallback 读到时同步写回
          return pid;
        } catch { /**/ }
      }
    } catch { /**/ }
  }
  return null;
}

function writePidFiles(pid) {
  ensureDir(DATA_DIR);
  fs.writeFileSync(PID_FILE, String(pid));
  try { fs.writeFileSync(OPENRC_PID, String(pid)); } catch { /**/ }
}

function writePid(pid) { writePidFiles(pid); }

function isRunning() {
  return readPid() !== null;  // readPid() 已含存活检查
}

