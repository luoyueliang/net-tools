// ─── 主入口 ──────────────────────────────────────────────────
const [,, cmd, ...args] = process.argv;

(async () => {
  switch (cmd) {
    case 'start':       await cmdStart(); break;
    case 'stop':        cmdStop(); break;
    case 'restart':     cmdStop(); await new Promise(r => setTimeout(r, 800)); await cmdStart(); break;
    case 'status':      cmdStatus(); break;
    case 'reload':      cmdReload(); break;
    case 'upgrade':     await cmdUpgrade(); break;
    case 'autostart':   cmdAutostart(args); break;
    case 'user':        cmdUser(args); break;
    case 'reality':     cmdReality(args); break;
    case 'selfservice': cmdSelfservice(args); break;
    case 'config':      cmdConfig(args); break;
    case 'firewall':    cmdFirewall(args); break;
    case 'export':      cmdExport(); break;
    case 'ui':          startApiServer(); console.log(c.green(`✓ Web UI 已启动 → http://127.0.0.1:${API_PORT}/`)); break;
    case 'help': case '--help': case '-h': printHelp(); break;
    default:
      if (!cmd) { cmdStatus(); }
      else { console.log(c.red(`未知命令: ${cmd}`)); printHelp(); }
  }
})();
