// ─── 工具函数 ────────────────────────────────────────────────
function run(cmd) {
  try { return execSync(cmd, { encoding: 'utf8' }).trim(); }
  catch { return ''; }
}

// ─── 平台检测 ────────────────────────────────────────────────
function detectPlatform() {
  if (process.platform === 'darwin') return 'macos';
  if (fs.existsSync('/etc/alpine-release'))  return 'alpine';
  if (process.platform === 'linux')   return 'linux';
  if (process.platform === 'freebsd') return 'freebsd';
  return 'linux';
}

// ─── 开机自启管理（跨平台）─────────────────────────────────
const AUTOSTART = {
  macos: {
    isEnabled()  { return fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED); },
    enable() {
      if (fs.existsSync(PLIST_DISABLED)) fs.renameSync(PLIST_DISABLED, PLIST);
      else if (!fs.existsSync(PLIST)) throw new Error('plist 文件不存在，请重新安装');
      run(`launchctl load "${PLIST}" 2>/dev/null || true`);
      console.log(c.green('✓ 已启用开机自启'));
      console.log(c.dim(`  plist: ${PLIST}`));
    },
    disable() {
      if (fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED)) {
        run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
        fs.renameSync(PLIST, PLIST_DISABLED);
      }
      console.log(c.dim('✓ 已禁用开机自启（当前进程不受影响）'));
    },
  },
  linux: {
    isEnabled()  { return run('systemctl is-enabled smartxray 2>/dev/null').includes('enabled'); },
    enable()     { run('sudo systemctl enable smartxray 2>/dev/null || true'); console.log(c.green('✓ 已启用开机自启 (systemctl enable smartxray)')); },
    disable()    { run('sudo systemctl disable smartxray 2>/dev/null || true'); console.log(c.dim('✓ 已禁用开机自启')); },
  },
  alpine: {
