// ─── 命令：lan（无认证 LAN 入站管理）────────────────────────
function cmdLan(args) {
  const sub = args[0];

  function getLan() {
    try {
      const parsed = JSON.parse(getSetting('lan_inbounds', '[]'));
      return Array.isArray(parsed) ? parsed : [];
    } catch { return []; }
  }
  function setLan(arr) {
    setSetting('lan_inbounds', JSON.stringify(arr));
  }

  if (!sub || sub === 'list') {
    const inbounds = getLan();
    console.log(c.bold('\n── LAN 入站（无认证）──────────────────────────────────'));
    if (!inbounds.length) {
      console.log(c.dim('  暂无 LAN 入站'));
      console.log(c.dim('  添加示例: xray-ctl lan add http  192.168.0.3 7890'));
      console.log(c.dim('            xray-ctl lan add socks 192.168.0.3 1080'));
    } else {
      for (const b of inbounds) {
        console.log(`  ${c.cyan(b.protocol.padEnd(6))} ${b.listen}:${c.bold(String(b.port))}  tag=${b.tag}`);
      }
    }
    console.log('');
    return;
  }

  if (sub === 'add') {
    const proto = (args[1] || 'http').toLowerCase();
    const bind  = args[2];
    const port  = parseInt(args[3]);
    if (!bind || !port) {
      console.log(c.red('用法: xray-ctl lan add [http|socks] <bind_ip> <port>'));
      return;
    }
    if (!['http', 'socks'].includes(proto)) {
      console.log(c.red('协议必须为 http 或 socks'));
      return;
    }
    const tag = `lan-${proto}-${port}`;
    const arr = getLan().filter(b => b.port !== port);  // 同端口覆盖
    const entry = { tag, listen: bind, port, protocol: proto };
    if (proto === 'socks') {
      entry.settings = { auth: 'noauth', udp: true };
      entry.sniffing = { enabled: true, destOverride: ['http', 'tls'] };
    } else {
      entry.settings = {};
    }
    arr.push(entry);
    setLan(arr);
    cmdReload();
    console.log(c.green(`✓ LAN ${proto.toUpperCase()} 入站已添加: ${bind}:${port}（无认证）`));
    return;
  }

  if (sub === 'del' || sub === 'remove') {
    const key = args[1];
    if (!key) { console.log(c.red('用法: xray-ctl lan del <tag|port>')); return; }
    const arr = getLan();
    const idx = arr.findIndex(b => b.tag === key || String(b.port) === key);
    if (idx < 0) { console.log(c.red(`✗ 未找到: ${key}`)); return; }
    const removed = arr.splice(idx, 1)[0];
    setLan(arr);
    cmdReload();
    console.log(c.green(`✓ LAN 入站已删除: ${removed.tag} (${removed.listen}:${removed.port})`));
    return;
  }

  console.log(c.dim('用法: xray-ctl lan [list | add [http|socks] <IP> <端口> | del <tag|端口>]'));
}

