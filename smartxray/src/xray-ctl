  }

  if (sub === 'lightsail') {
    const instance = args[1];
    if (!instance) { console.log(c.red('用法: xray-ctl firewall lightsail <实例名>')); return; }
    setSetting('extfw_mode', 'lightsail');
    setSetting('lightsail_instance', instance);
    console.log(c.green(`✓ AWS Lightsail 防火墙模式已启用`));
    console.log(`  实例: ${c.cyan(instance)}`);
    console.log(c.dim('  新建/删除用户时会自动同步 Lightsail 安全组端口'));
    return;
  }

  if (sub === 'openwrt') {
    const host    = args[1];
    const user    = args[2] || getSetting('openwrt_user', 'root');
    const keyPath = args[3] || getSetting('openwrt_ssh_key', '');
    const destIp  = args[4] || getSetting('openwrt_dest_ip', '');
    if (!host) { console.log(c.red('用法: xray-ctl firewall openwrt <路由器IP> [ssh用户] [ssh密钥路径] [服务器LAN-IP]')); return; }
    setSetting('extfw_mode', 'openwrt');
    setSetting('openwrt_host', host);
    setSetting('openwrt_user', user);
    if (keyPath) setSetting('openwrt_ssh_key', keyPath);
    if (destIp)  setSetting('openwrt_dest_ip', destIp);
    console.log(c.green('✓ OpenWrt 防火墙模式已启用'));
    console.log(`  路由器: ${c.cyan(host)}  用户: ${user}  密钥: ${keyPath || '(系统默认)'}`);
    if (destIp) console.log(`  服务器 LAN IP: ${c.cyan(destIp)}`);
    else console.log(c.yellow('  ⚠ 未设置服务器 LAN IP，请补充:') + c.dim(` xray-ctl firewall openwrt ${host} ${user} ${keyPath} <LAN-IP>`));
    return;
  }

  if (sub === 'off') {
    setSetting('extfw_mode', 'none');
    console.log(c.green('✓ 外部防火墙模式已关闭'));
    return;
  }

  if (sub === 'sync') {
    const users   = db().prepare('SELECT * FROM users WHERE enabled=1').all();
    const reality = getRealityConfig();
    const syncing = mode === 'lightsail' ? 'Lightsail' : mode === 'openwrt' ? 'OpenWrt' : null;
    if (!syncing) { console.log(c.yellow('⚠ 未配置外部防火墙，无需同步')); return; }
    console.log(c.bold(`\n── 同步端口到 ${syncing} ─────────────────────────`));
    for (const u of users) {
      extFwOp('open', u.port);
      if (u.http_port) extFwOp('open', u.http_port);
      console.log(c.dim(`  ✓ ${u.name}: ${u.port}${u.http_port ? ' + ' + u.http_port : ''}`));
    }
    if (reality.enabled) {
      extFwOp('open', reality.port);
      console.log(c.dim(`  ✓ Reality: ${reality.port}`));
    }
    console.log(c.green(`✓ 端口同步完成（共 ${users.length} 用户）`));
    return;
  }

  console.log(c.dim('用法: xray-ctl firewall [lightsail <实例名> | openwrt <IP> [用户] [密钥] [LAN-IP] | off | sync]'));
}

