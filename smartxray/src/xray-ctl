// ==================== 主入口 ====================
const [,, cmd, ...args] = process.argv;

(async () => {
  try {
    switch (cmd) {
      case 'start':
        await cmdStart();
        break;
      case 'stop':
        cmdStop();
        break;
      case 'restart':
        cmdStop();
        await new Promise(r => setTimeout(r, 800));
        await cmdStart();
        break;
      case 'status':
        cmdStatus();
        break;
      case 'reload':
        cmdReload();
        break;
      case 'user':
        cmdUser(args);
        break;
      case 'reality':
        cmdReality(args);
        break;
      case 'config':
        cmdConfig(args);
        break;
      case 'firewall':
        cmdFirewall(args);
        break;
      case 'ui':
        cmdUI();
        break;
      case 'help':
      case '--help':
      case '-h':
        printHelp();
        break;
      default:
        if (!cmd) {
          cmdStatus();
        } else {
          console.log(c.red(`未知命令: ${cmd}`));
          printHelp();
        }
    }
  } catch (e) {
    console.error(c.red(`错误: ${e.message}`));
    process.exit(1);
  } finally {
    // 关闭数据库连接
    database.closeDb();
  }
})();