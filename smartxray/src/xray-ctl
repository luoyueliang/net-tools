// ─── 命令：start ─────────────────────────────────────────────
async function cmdStart() {
  if (isRunning()) {
    console.log(c.yellow('⚠ Xray 已在运行'));
    return;
  }
  if (!fs.existsSync(BIN)) {
    console.log(c.red(`✗ 找不到 xray 二进制: ${BIN}`));
    console.log(c.dim('  请先运行: node scripts/install.js'));
    return;
  }
  ensureDir(DATA_DIR);
  ensureDir(path.dirname(LOG_FILE));
  buildConfig();
  console.log('启动 Xray...');
  const child = spawn(BIN, ['run', '-c', XRAY_CONF], {
    detached: true,
    stdio: ['ignore', 'ignore', 'ignore'],
  });
  child.unref();
  writePid(child.pid);
  await new Promise(r => setTimeout(r, 1200));
  if (isRunning()) {
    console.log(c.green(`✓ Xray 已启动  PID=${child.pid}`));
    startApiServer();
  } else {
    console.log(c.red('✗ 启动失败，检查日志: ' + LOG_FILE));
  }
}

// ─── 命令：stop ──────────────────────────────────────────────
function cmdStop() {
  const pid = readPid();
  if (!pid || !isRunning()) {
    console.log(c.yellow('⚠ Xray 未运行'));
    return;
  }
  try {
    process.kill(pid, 'SIGTERM');
    fs.unlinkSync(PID_FILE);
    console.log(c.green('✓ Xray 已停止'));
  } catch (e) {
    console.log(c.red(`✗ 停止失败: ${e.message}`));
  }
}

// ─── 命令：reload（热重载配置）────────────────────────────────
function cmdReload() {
  buildConfig();
  exportMihomoProxies();
  const pid = readPid();
  if (pid && isRunning()) {
    try {
      process.kill(pid, 'SIGUSR1');   // xray 支持 SIGUSR1 热重载
      console.log(c.green('✓ 配置已重载 (SIGUSR1)'));
    } catch {
      console.log(c.yellow('⚠ 无法发送 SIGUSR1，重启进程...'));
      cmdStop();
      setTimeout(cmdStart, 500);
    }
  } else {
    console.log(c.dim('  Xray 未运行，已更新配置文件'));
  }
}

// ─── 命令：user ──────────────────────────────────────────────
function cmdUser(args) {
  const sub = args[0];

  if (!sub || sub === 'list') {
    const users = db().prepare('SELECT * FROM users ORDER BY port').all();
    const now   = new Date();
    if (!users.length) { console.log(c.yellow('  尚无用户，运行: xray-ctl user add <名称>')); return; }
    console.log(c.bold('\n── 用户列表 ──────────────────────────────────'));
    for (const u of users) {
      const st  = u.enabled ? c.green('✓') : c.dim('✗');
      const vl  = u.uuid ? c.cyan(' VLESS✓') : '';
      const exp = u.expires_at
        ? (new Date(u.expires_at) > now ? c.yellow(` 到期:${fmtDate(u.expires_at)}`) : c.red(' 已过期'))
        : '';
      console.log(`  ${st} [${u.id}] ${c.bold(u.name.padEnd(18))} socks:${u.port}  http:${u.http_port || '—'}  ${u.username}/${u.password}${vl}${exp}`);
    }
    return;
  }

  if (sub === 'add') {
    const name     = args[1] || `user-${Date.now()}`;
    const username = args[2] || randStr(8);
    const password = args[3] || randStr(12);
    const hours    = parseInt(args[4]) || 0;
    let socksPort, httpPort;
    try {
      socksPort = allocPort(SOCKS_MIN, SOCKS_MAX);
      httpPort  = allocPort(HTTP_MIN,  HTTP_MAX);
    } catch (e) { console.log(c.red('✗ ' + e.message)); return; }
    const uuid      = newUUID();
    const tag       = `u-${name}-${socksPort}`;
    const expiresAt = hours > 0 ? new Date(Date.now() + hours * 3600000).toISOString() : null;
    try {
      db().prepare(`
        INSERT INTO users (name,port,http_port,uuid,protocol,username,password,tag,expires_at)
        VALUES (?,?,?,?,'socks',?,?,?,?)
      `).run(name, socksPort, httpPort, uuid, username, password, tag, expiresAt);
      firewallOpen(socksPort);
      firewallOpen(httpPort);
      cmdReload();
      console.log(c.green(`✓ 用户 "${name}" 已创建`));
      console.log(`  SOCKS5  | 端口: ${c.cyan(socksPort)} | ${c.cyan(username)} / ${c.cyan(password)}`);
      console.log(`  HTTP    | 端口: ${c.cyan(httpPort)} | ${c.cyan(username)} / ${c.cyan(password)}`);
      const reality = getRealityConfig();
      if (reality.enabled && reality.publicKey) {
        console.log(`  VLESS   | 端口: ${c.cyan(reality.port)} | UUID: ${c.cyan(uuid)}`);
        console.log(`  Reality | PublicKey: ${c.dim(reality.publicKey)}`);
        console.log(`          | ShortId: ${c.dim(reality.shortIds[0] || '')}  SNI: ${reality.serverNames[0]}`);
      }
      if (expiresAt) console.log(c.yellow(`  有效期  | ${fmtDate(expiresAt)} (${hours}h)`));
    } catch (e) {
      if (e.message.includes('UNIQUE')) console.log(c.red(`✗ 用户 "${name}" 已存在`));
      else console.log(c.red('✗ 添加失败: ' + e.message));
    }
    return;
  }

  if (sub === 'del' || sub === 'delete' || sub === 'remove') {
    const u = db().prepare('SELECT * FROM users WHERE name=? OR id=?').get(args[1], parseInt(args[1]) || 0);
    if (!u) { console.log(c.red(`✗ 未找到 "${args[1]}"`)); return; }
    db().prepare('DELETE FROM users WHERE id=?').run(u.id);
    firewallClose(u.port);
    firewallClose(u.http_port);
    cmdReload();
    console.log(c.green(`✓ 用户 "${u.name}" 已删除`));
    return;
  }

  if (sub === 'enable' || sub === 'disable') {
    const u = db().prepare('SELECT * FROM users WHERE name=? OR id=?').get(args[1], parseInt(args[1]) || 0);
    if (!u) { console.log(c.red(`✗ 未找到 "${args[1]}"`)); return; }
    const en = sub === 'enable' ? 1 : 0;
    db().prepare('UPDATE users SET enabled=? WHERE id=?').run(en, u.id);
    if (en) { firewallOpen(u.port); firewallOpen(u.http_port); }
    else    { firewallClose(u.port); firewallClose(u.http_port); }
    cmdReload();
    console.log(c.green(`✓ "${u.name}" 已${sub === 'enable' ? '启用' : '禁用'}`));
    return;
  }

  if (sub === 'passwd') {
    const u = db().prepare('SELECT * FROM users WHERE name=? OR id=?').get(args[1], parseInt(args[1]) || 0);
    if (!u) { console.log(c.red(`✗ 未找到 "${args[1]}"`)); return; }
    const np = args[2] || randStr(12);
    db().prepare('UPDATE users SET password=? WHERE id=?').run(np, u.id);
    cmdReload();
    console.log(c.green(`✓ 密码已更新: ${c.cyan(np)}`));
    return;
  }

  console.log(c.dim('用法: xray-ctl user [list|add <名称> [用户名] [密码] [有效小时] | del | enable | disable | passwd] ...'));
}

// ─── 新命令：reality ──────────────────────────────────────
function cmdReality(args) {
  const sub = args[0] || 'show';

  if (sub === 'init') {
    const port    = parseInt(args[1]) || 8443;
    const dest    = args[2] || 'www.microsoft.com:443';
    const sni     = dest.split(':')[0];
    const shortId = randHex(8);

    // 生成 x25519 密鑰对（兼容旧版 "Private key:" 和新版 v26+ "PrivateKey: / Password:" 格式）
    let keyOut;
    try { keyOut = execSync(`${BIN} x25519`, { encoding: 'utf8' }); }
    catch (e) { console.log(c.red('✗ xray x25519 失败: ' + e.message)); return; }
    // v26+: "PrivateKey: xxx" + "Password: xxx"（Password 为公钥）
    // v1.x: "Private key: xxx" + "Public key: xxx"
    const priv = keyOut.match(/PrivateKey:\s*(\S+)/)?.[1] || keyOut.match(/Private key:\s*(\S+)/i)?.[1];
    const pub  = keyOut.match(/Password:\s*(\S+)/)?.[1]   || keyOut.match(/Public key:\s*(\S+)/i)?.[1];
    if (!priv || !pub) { console.log(c.red('✗ 解析密鑰失败，xray x25519 输出:\n' + keyOut)); return; }

    setSetting('reality_enabled',      '1');
    setSetting('reality_port',         String(port));
    setSetting('reality_private_key',  priv);
    setSetting('reality_public_key',   pub);
    setSetting('reality_short_ids',    shortId);
    setSetting('reality_dest',         dest);
    setSetting('reality_server_names', sni);

    // 为已有用户分配 UUID
    const users = db().prepare('SELECT id, uuid FROM users WHERE uuid IS NULL OR uuid = \'\'').all();
    for (const u of users) {
      db().prepare('UPDATE users SET uuid=? WHERE id=?').run(newUUID(), u.id);
    }
    firewallOpen(port);
    cmdReload();

    console.log(c.green(`✓ Reality 已初始化 (port=${port} sni=${sni})`));
    console.log(`  PublicKey : ${c.cyan(pub)}`);
    console.log(`  PrivateKey: ${c.dim(priv)}`);
    console.log(`  ShortId   : ${c.cyan(shortId)}`);
    if (users.length) console.log(c.dim(`  建议对已有 ${users.length} 个用户运行: xray-ctl user list`));
    return;
  }

  // 导入现有 Reality 密鑰（迁移时使用，保持原有客户端配置不变）
  // 用法: xray-ctl reality import <privateKey> <publicKey> [port] [shortId] [dest]
  if (sub === 'import') {
    const privKey = args[1];
    const pubKey  = args[2];
    const port    = parseInt(args[3]) || 8443;
    const shortId = args[4] || randHex(8);
    const dest    = args[5] || 'www.microsoft.com:443';
    const sni     = dest.split(':')[0];
    if (!privKey || !pubKey) {
      console.log(c.red('用法: xray-ctl reality import <privateKey> <publicKey> [port] [shortId] [dest]'));
      return;
    }
    setSetting('reality_enabled',      '1');
    setSetting('reality_port',         String(port));
    setSetting('reality_private_key',  privKey);
    setSetting('reality_public_key',   pubKey);
    setSetting('reality_short_ids',    shortId);
    setSetting('reality_dest',         dest);
    setSetting('reality_server_names', sni);
    // 为已有用户补充 UUID
    const users = db().prepare('SELECT id, uuid FROM users WHERE uuid IS NULL OR uuid = \'\'').all();
    for (const u of users) {
      db().prepare('UPDATE users SET uuid=? WHERE id=?').run(newUUID(), u.id);
    }
    cmdReload();
    console.log(c.green(`✓ Reality 密鑰已导入 (port=${port} sni=${sni})`));
    console.log(`  PublicKey : ${c.cyan(pubKey)}`);
    console.log(`  ShortId   : ${c.cyan(shortId)}`);
    return;
  }

  if (sub === 'show') {
    const r = getRealityConfig();
    console.log(c.bold('\n── Reality 配置 ───────────────────────────────'));
    console.log(`  状态      : ${r.enabled ? c.green('启用') : c.red('未启用')}`);
    console.log(`  端口      : ${r.port}`);
    console.log(`  PublicKey : ${c.cyan(r.publicKey || '未设置')}`);
    console.log(`  ShortIds  : ${r.shortIds.join(',') || '未设置'}`);
    console.log(`  伪装目标  : ${r.dest}`);
    console.log(`  SNI       : ${r.serverNames.join(',')}
`);
    return;
  }

  if (sub === 'disable') {
    setSetting('reality_enabled', '0');
    cmdReload();
    console.log(c.green('✓ Reality 已禁用'));
    return;
  }

  console.log(c.dim('用法: xray-ctl reality [init [port] [dest] | import <priv> <pub> [port] [shortId] [dest] | show | disable]'));
}

