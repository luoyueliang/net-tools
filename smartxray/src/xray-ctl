// ─── 发送验证邮件 ───────────────────────────────────────️
async function sendMail(to, subject, text) {
  let nodemailer;
  try { nodemailer = require('nodemailer'); }
  catch { throw new Error('nodemailer 未安装: cd smartxray && npm install'); }
  const transporter = nodemailer.createTransport({
    host:   getSetting('smtp_host'),
    port:   parseInt(getSetting('smtp_port', '587')),
    secure: getSetting('smtp_secure') === '1',
    auth:   { user: getSetting('smtp_user'), pass: getSetting('smtp_pass') },
  });
  await transporter.sendMail({
    from:    getSetting('smtp_from') || getSetting('smtp_user'),
    to,
    subject,
    text,
  });
}

// ─── 过期账户时隔清理 ────────────────────────────────────
function cleanupExpired() {
  const now     = new Date().toISOString();
  const expired = db().prepare('SELECT * FROM users WHERE expires_at IS NOT NULL AND expires_at < ?').all(now);
  if (expired.length) {
    for (const u of expired) {
      db().prepare('DELETE FROM users WHERE id=?').run(u.id);
      firewallClose(u.port);
      firewallClose(u.http_port);
    }
    console.log(c.dim(`[cleanup] 删除 ${expired.length} 个过期账户`));
    cmdReload();
  }
  // 清理过期验证码
  db().prepare('DELETE FROM verifications WHERE expires_at < ?').run(now);
}

