#!/bin/sh /etc/rc.common
# __TOOL_NAME__ OpenWrt init script
START=99
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/local/bin/__BIN_NAME__ --config /etc/__TOOL_NAME__/config.yaml
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
