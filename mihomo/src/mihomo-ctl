// ─── 命令：geo ─────────────────────────────────────────────────
const GEO_FILES = [
  { name: 'geoip.dat',   url: 'https://github.com/MetaCubeX/meta-rules-dat/releases/latest/download/geoip.dat' },
  { name: 'geosite.dat', url: 'https://github.com/MetaCubeX/meta-rules-dat/releases/latest/download/geosite.dat' },
];

async function cmdGeoUpdate() {
  const fs = require('fs');
  fs.mkdirSync(DATA_DIR, { recursive: true });
  console.log(c.bold('\n── GeoIP / GeoSite 更新 ──────────────────────'));
  let ok = 0;
  for (const { name, url } of GEO_FILES) {
    const dst = `${DATA_DIR}/${name}`;
    const tmp = `/tmp/${name}.tmp`;
    process.stdout.write(`  下载 ${name}... `);
    try {
      run(`curl -4 -L --max-time 60 -o "${tmp}" "${url}" 2>/dev/null`);
      if (!require('fs').existsSync(tmp) || require('fs').statSync(tmp).size < 100000) {
        console.log(c.red('✗ 下载失败或文件过小')); continue;
      }
      fs.renameSync(tmp, dst);
      const size = (fs.statSync(dst).size / 1024 / 1024).toFixed(1);
      console.log(c.green(`✓ ${size} MB`));
      ok++;
    } catch (e) { console.log(c.red(`✗ ${e.message}`)); }
  }
  if (ok > 0) {
    if (await isRunning()) {
      process.stdout.write('  通知 Mihomo 热重载... ');
      try { await cmdReload(true); console.log(c.green('✓')); }
      catch { console.log(c.yellow('⚠ 热重载失败，重启生效: mihomo-ctl restart')); }
    } else {
      console.log(c.dim('  Mihomo 未运行，下次启动时生效'));
    }
  }
}

function cmdGeoSchedule(action) {
  const fs = require('fs');
  const logPath = `${process.env.HOME}/.config/mihomo/logs/geo-update.log`;
  const cronLine = `0 3 * * 1 /usr/local/bin/mihomo-ctl geo update >> "${logPath}" 2>&1 ${GEO_CRON_TAG}`;
  const current = run('crontab -l 2>/dev/null') || '';
  const hasJob  = current.includes(GEO_CRON_TAG);

  if (!action) {
    console.log(hasJob
      ? c.green('  GeoIP 定时更新: 已启用（每周一 03:00）')
      : c.dim('  GeoIP 定时更新: 未启用'));
    console.log(c.dim('  启用: mihomo-ctl geo schedule'));
    console.log(c.dim('  禁用: mihomo-ctl geo unschedule'));
    return;
  }
  const writeCrontab = content => {
    const tmp = '/tmp/mihomo-crontab.tmp';
    fs.writeFileSync(tmp, content.trim() ? content.trim() + '\n' : '');
    run(content.trim() ? `crontab "${tmp}"` : 'crontab -r 2>/dev/null || true');
    try { fs.unlinkSync(tmp); } catch {}
  };
  if (action === 'schedule') {
    if (hasJob) { console.log(c.dim('  定时任务已存在')); return; }
    writeCrontab(current ? `${current}\n${cronLine}` : cronLine);
    console.log(c.green('✓ 已设置 GeoIP 每周一 03:00 自动更新'));
    console.log(c.dim(`  日志: ${logPath}`));
  } else if (action === 'unschedule') {
    writeCrontab(current.split('\n').filter(l => !l.includes(GEO_CRON_TAG)).join('\n'));
    console.log(c.dim('✓ GeoIP 定时更新已取消'));
  }
}

async function cmdGeo(sub) {
  if (sub === 'update')     return cmdGeoUpdate();
  if (sub === 'schedule')   return cmdGeoSchedule('schedule');
  if (sub === 'unschedule') return cmdGeoSchedule('unschedule');
  const fs = require('fs');
  console.log(c.bold('\n── GeoIP 状态 ────────────────────────────────'));
  for (const { name } of GEO_FILES) {
    const p = `${DATA_DIR}/${name}`;
    if (fs.existsSync(p)) {
      const days = Math.floor((Date.now() - fs.statSync(p).mtimeMs) / 86400000);
      const size = (fs.statSync(p).size / 1024 / 1024).toFixed(1);
      const age  = days === 0 ? '今天' : `${days} 天前`;
      console.log(`  ${name.padEnd(16)} ${(size + ' MB').padEnd(10)} 更新于 ${days > 30 ? c.yellow(age) : c.dim(age)}`);
    } else {
      console.log(`  ${name.padEnd(16)} ${c.red('未下载')}`);
    }
  }
  console.log('');
  cmdGeoSchedule(null);
  console.log(c.dim('\n  立即更新: mihomo-ctl geo update'));
}

// ─── 命令：reload ──────────────────────────────────────────────
async function cmdReload(quiet = false) {
  if (!(await isRunning())) {
    if (!quiet) console.log(c.red('Mihomo 未运行'));
    return;
  }
  return new Promise((resolve, reject) => {
    const body = JSON.stringify({ path: CONFIG });
    const req  = http.request({
      hostname: '127.0.0.1', port: 9090,
      path: '/configs?force=true', method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) },
      timeout: 5000,
    }, res => {
      res.resume();
      if (!quiet) {
        if (res.statusCode === 204) console.log(c.green('✓ 配置已热重载（连接不中断）'));
        else console.log(c.yellow(`⚠ 返回 ${res.statusCode}，查看日志: mihomo-ctl log-on`));
      }
      resolve(res.statusCode);
    });
    req.on('error', e => { if (!quiet) console.log(c.red(`✗ ${e.message}`)); reject(e); });
    req.write(body); req.end();
  });
}

// ─── 命令：mode ────────────────────────────────────────────────
async function cmdMode(mode) {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }
  const validModes = ['rule', 'global', 'direct'];
  if (!mode) {
    const cfg = await apiGet('/configs').catch(() => ({}));
    console.log(`\n  当前模式: ${c.cyan(cfg.mode || '?')}`);
    console.log(c.dim('  切换: mihomo-ctl mode [rule|global|direct]'));
    return;
  }
  if (!validModes.includes(mode)) {
    console.log(c.red(`✗ 无效模式: ${mode}\n  可选: rule | global | direct`)); return;
  }
  try {
    await new Promise((resolve, reject) => {
      const data = JSON.stringify({ mode });
      const req  = http.request({
        hostname: '127.0.0.1', port: 9090, path: '/configs', method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) },
        timeout: 3000,
      }, res => { res.resume(); resolve(); });
      req.on('error', reject); req.write(data); req.end();
    });
    // 同步写入配置文件，避免重启后回滚
    const fs = require('fs');
    if (fs.existsSync(CONFIG)) {
      fs.writeFileSync(CONFIG, fs.readFileSync(CONFIG, 'utf8').replace(/^mode:.*$/m, `mode: ${mode}`));
    }
    const labels = { rule: '规则分流', global: '全局代理（全部流量走代理）', direct: '全局直连（跳过代理）' };
    console.log(c.green(`✓ 模式已切换 → ${labels[mode]}`));
  } catch (e) { console.log(c.red(`✗ 切换失败: ${e.message}`)); }
}

// ─── 命令：traffic ─────────────────────────────────────────────
async function cmdTraffic() {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }
  console.log(c.bold('\n── 实时流量 ─────────────────────────────────'));
  console.log(c.dim('  按 Ctrl+C 退出\n'));
  const fmtSpeed = b => b > 1e6 ? `${(b/1e6).toFixed(1)} MB/s` : b > 1e3 ? `${(b/1e3).toFixed(0)} KB/s` : `${b} B/s`;
  const req = http.get(`${API}/traffic`, { timeout: 0 }, res => {
    res.on('data', chunk => {
      try {
        // SSE 每行可能带 "data: " 前缀
        const raw = chunk.toString().replace(/^data:\s*/m, '').trim();
        const { up = 0, down = 0 } = JSON.parse(raw);
        process.stdout.write(`\r  \u2191 ${c.yellow(fmtSpeed(up).padEnd(12))}  \u2193 ${c.cyan(fmtSpeed(down).padEnd(12))}  `);
      } catch {}
    });
    res.on('end', () => console.log('\n  连接已关闭'));
  });
  req.on('error', e => console.log(c.red(`✗ ${e.message}`)));
  process.on('SIGINT', () => { req.destroy(); console.log(''); process.exit(0); });
}

// ─── 命令：connections ─────────────────────────────────────────
async function cmdConnections(action) {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }
  if (action === 'close-all') {
    await new Promise((resolve, reject) => {
      const req = http.request({
        hostname: '127.0.0.1', port: 9090, path: '/connections', method: 'DELETE', timeout: 3000,
      }, res => { res.resume(); resolve(); });
      req.on('error', reject); req.end();
    });
    console.log(c.green('✓ 已关闭所有连接'));
    return;
  }
  const data  = await apiGet('/connections');
  const conns = data.connections || [];
  const { downloadTotal = 0, uploadTotal = 0 } = data;
  const fmtB  = b => b > 1e9 ? `${(b/1e9).toFixed(2)} GB` : b > 1e6 ? `${(b/1e6).toFixed(1)} MB` : b > 1e3 ? `${(b/1e3).toFixed(0)} KB` : `${b} B`;
  console.log(c.bold(`\n── 活跃连接 (${conns.length}) ─────────────────────────`));
  console.log(`  总计: \u2193${c.cyan(fmtB(downloadTotal))}  \u2191${c.yellow(fmtB(uploadTotal))}\n`);
  for (const conn of conns.slice(0, 25)) {
    const host  = (conn.metadata?.host || conn.metadata?.destinationIP || '?').padEnd(36);
    const chain = (conn.chains || []).join(' → ');
    console.log(`  ${c.cyan(host)} \u2193${fmtB(conn.download||0).padStart(8)}  \u2191${fmtB(conn.upload||0).padStart(8)}  ${c.dim(chain)}`);
  }
  if (conns.length > 25) console.log(c.dim(`  ... 还有 ${conns.length - 25} 条`));
  console.log(c.dim('\n  断开所有连接: mihomo-ctl connections close-all'));
}

// ─── 命令：check ────────────────────────────────────────────────
function cmdCheck() {
  console.log(c.bold('\n── 配置语法检查 ──────────────────────────────'));
  console.log(c.dim(`  文件: ${CONFIG}\n`));
  const result = run(`"${BIN}" -t -d "${process.env.HOME}/.config/mihomo" 2>&1`);
  if (/success|parse config/i.test(result) || result === '') {
    console.log(c.green('✓ 配置文件语法正确'));
  } else {
    console.log(c.red('✗ 配置文件存在错误:\n'));
    result.split('\n').forEach(l => console.log('  ' + (l.includes('ERR') ? c.red(l) : c.yellow(l))));
    console.log(c.dim('\n  修复后热重载: mihomo-ctl reload'));
  }
}

// ─── 命令：start / stop / restart ─────────────────────────────
async function cmdStart() {
  const fs   = require('fs');
  const path = require('path');
  // 如果已运行则确保代理和 DNS 状态正确
  if (run('pgrep -f \'mihomo -d\' 2>/dev/null')) {
    console.log(c.yellow('⚠ Mihomo 已在运行，自动确认系统代理状态...'));
    await cmdProxyOn();
    if (fs.existsSync(DNS_AUTOSTART_FILE)) await cmdDnsOn();
    return;
  }
  // 确保日志目录存在（否则 shell 重定向会失败，进程不会启动）
  const logsDir = path.dirname(LOG);
  if (!fs.existsSync(logsDir)) fs.mkdirSync(logsDir, { recursive: true });

  console.log('启动 Mihomo...');
  const plistToLoad = fs.existsSync(PLIST) ? PLIST : (fs.existsSync(PLIST_DISABLED) ? PLIST_DISABLED : null);
  if (plistToLoad && plistToLoad !== PLIST_DISABLED) {
    run(`launchctl load "${PLIST}" 2>/dev/null || true`);
  } else {
    // 直接启动：plist 不存在或已禁用（autostart off）
    exec(`/usr/local/bin/mihomo -d "${process.env.HOME}/.config/mihomo" >> "${LOG}" 2>&1 &`);
  }
  setTimeout(async () => {
    if (await isRunning()) {
      console.log(c.green('✓ 已启动'));
      await cmdProxyOn();
      if (require('fs').existsSync(DNS_AUTOSTART_FILE)) await cmdDnsOn();
    } else {
      console.log(c.red(`✗ 启动失败，开启日志后重试: mihomo-ctl log-on && mihomo-ctl restart`));
    }
  }, 1500);
}

function isDnsManagedByMihomo() {
  const fs = require('fs');
  if (!fs.existsSync(DNS_BACKUP_FILE)) return false;
  const sysDns = run('scutil --dns 2>/dev/null | grep "nameserver\\[0\\]" | head -1');
  return sysDns.includes('127.0.0.1');
}

async function cmdStop() {
  const dnsManaged   = isDnsManagedByMihomo();
  const proxyManaged = isSystemProxySetToMihomo();
  process.stdout.write(proxyManaged ? '  系统代理接管中，先关闭代理... ' : '  关闭系统代理... ');
  await cmdProxyOff();
  if (dnsManaged) {
    console.log(c.yellow('  DNS 接管中，先恢复 DNS...'));
    await cmdDnsOff();
  }
  console.log('停止 Mihomo...');
  run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
  run(`pkill -f 'mihomo -d' 2>/dev/null || true`);
  setTimeout(async () => {
    if (!(await isRunning())) {
      const notes = ['系统代理已关闭', dnsManaged && 'DNS 已恢复 DHCP'].filter(Boolean);
      console.log(c.green('✓ 已停止' + (notes.length ? '，' + notes.join('，') : '')));
    } else {
      console.log(c.yellow('进程仍在，手动: sudo kill $(pgrep -f "mihomo -d")'));
    }
  }, 1000);
}

async function cmdRestart() {
  const dnsManaged   = isDnsManagedByMihomo();
  const proxyManaged = isSystemProxySetToMihomo();
  process.stdout.write(proxyManaged ? '  系统代理接管中，先关闭代理... ' : '  关闭系统代理... ');
  await cmdProxyOff();
  if (dnsManaged) {
    console.log(c.yellow('  DNS 接管中，先恢复 DNS...'));
    await cmdDnsOff();
  }
  console.log('重启 Mihomo...');
  run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
  run(`pkill -f 'mihomo -d' 2>/dev/null || true`);
  setTimeout(() => {
    const fs = require('fs');
    if (fs.existsSync(PLIST)) run(`launchctl load "${PLIST}" 2>/dev/null || true`);
    else exec(`/usr/local/bin/mihomo -d ${process.env.HOME}/.config/mihomo >> "${LOG}" 2>&1 &`);
    setTimeout(async () => {
      if (await isRunning()) {
        console.log(c.green('✓ 已重启'));
        await cmdProxyOn();
        if (dnsManaged)   await cmdDnsOn();
      } else {
        console.log(c.red('✗ 重启失败，开启日志: mihomo-ctl log-on && mihomo-ctl restart'));
      }
    }, 1500);
  }, 1000);
}

// ─── 命令：log ─────────────────────────────────────────────────
function cmdLog() {
  const fs = require('fs');
  if (!fs.existsSync(LOG) || fs.statSync(LOG).size === 0) {
    console.log(c.dim('  日志为空（当前日志级别: silent）'));
    console.log(c.dim('  开启日志: mihomo-ctl log-on'));
    return;
  }
  console.log(c.dim(`日志文件: ${LOG}\n`));
  try {
    const lines = execSync(`tail -50 "${LOG}"`, { encoding: 'utf8' });
    const colored = lines.split('\n').map(l => {
      if (l.includes('ERR') || l.includes('error')) return c.red(l);
      if (l.includes('WARN'))  return c.yellow(l);
      if (l.includes('INFO'))  return c.dim(l);
      return l;
    }).join('\n');
    console.log(colored);
  } catch { console.log(c.red('读取日志失败')); }
  console.log(c.dim(`\n实时查看: tail -f ${LOG}`));
}

// ─── 命令：ui ──────────────────────────────────────────────────
async function cmdUi(sub) {
  const fs = require('fs');
  const path = require('path');

  // 找到本脚本同级的 ../ui/index.html
  const scriptDir = path.dirname(fs.realpathSync(process.argv[1]));
  const srcUi     = path.join(scriptDir, '..', 'ui', 'index.html');
  // 安装位置（mihomo external-ui 指向的目录）
  const dstUi     = UI_DIR;

  if (sub === 'install') {
    // 安装 UI 文件到 ~/.config/mihomo/ui/
    if (!fs.existsSync(srcUi)) {
      console.log(c.red(`✗ 找不到 UI 源文件: ${srcUi}`));
      console.log(c.dim('  请从仓库目录运行，或先 git clone net-tools'));
      return;
    }
    fs.mkdirSync(dstUi, { recursive: true });
    fs.copyFileSync(srcUi, path.join(dstUi, 'index.html'));
    console.log(c.green(`\n  ✓ UI 已安装: ${dstUi}/index.html`));

    // 写入 config.yaml 的 external-ui 字段
    if (fs.existsSync(CONFIG)) {
      let yaml = fs.readFileSync(CONFIG, 'utf8');
      if (yaml.includes('external-ui:')) {
        yaml = yaml.replace(/^external-ui:.*$/m, `external-ui: ${dstUi}`);
      } else if (yaml.includes('external-controller:')) {
        yaml = yaml.replace(
          /(external-controller:[^\n]*)/,
          `$1\nexternal-ui: ${dstUi}`
        );
      } else {
        yaml += `\nexternal-ui: ${dstUi}\n`;
      }
      fs.writeFileSync(CONFIG, yaml);
      console.log(c.dim(`  已更新 config.yaml: external-ui: ${dstUi}`));
    }

    console.log(c.dim('\n  重载配置: mihomo-ctl reload'));
    console.log(c.dim(`  访问: http://127.0.0.1:9090/ui/`));
    console.log(c.dim('  注意: 若 external-controller 仅绑定 127.0.0.1，无法远程访问'));
    return;
  }

  if (sub === 'open') {
    const url = 'http://127.0.0.1:9090/ui/';
    run(`open "${url}" 2>/dev/null || xdg-open "${url}" 2>/dev/null || echo "${url}"`);
    return;
  }

  // 默认：打印状态
  const installed = fs.existsSync(path.join(dstUi, 'index.html'));
  console.log(c.bold('\n── Mihomo Web UI ─────────────────────────────'));
  if (installed) {
    const stat = fs.statSync(path.join(dstUi, 'index.html'));
    const days = Math.floor((Date.now() - stat.mtimeMs) / 86400000);
    console.log(c.green(`  ✓ 已安装  更新于 ${days === 0 ? '今天' : days + ' 天前'}`));
    console.log(c.dim(`  路径: ${dstUi}/index.html`));
    console.log(c.dim('  访问: http://127.0.0.1:9090/ui/'));
  } else {
    console.log(c.dim('  未安装'));
    console.log(c.dim('  安装: mihomo-ctl ui install'));
  }
  console.log(c.dim('\n  子命令:'));
  console.log(c.dim('    mihomo-ctl ui install   安装/更新 Web UI'));
  console.log(c.dim('    mihomo-ctl ui open      浏览器打开'));
}

// ─── 命令：backup ──────────────────────────────────────────────
function cmdBackup() {
  const fs = require('fs');
  const ts        = new Date().toISOString().slice(0, 19).replace(/[T:]/g, '-');
  const backupDir = `${process.env.HOME}/.config/mihomo/backups/${ts}`;
  fs.mkdirSync(backupDir, { recursive: true });
  let count = 0;
  if (fs.existsSync(CONFIG)) {
    fs.copyFileSync(CONFIG, `${backupDir}/config.yaml`);
    count++;
  }
  if (count > 0) {
    console.log(c.green(`\n  ✓ 配置已备份`));
    console.log(c.dim(`  位置: ${backupDir}/config.yaml`));
    console.log(c.dim('  恢复: mihomo-ctl restore'));
  } else {
    console.log(c.yellow(`\n  ⚠ 未找到配置文件: ${CONFIG}`));
  }
}

// ─── 命令：restore ─────────────────────────────────────────────
function cmdRestore(dir) {
  const fs = require('fs');
  const backupsDir = `${process.env.HOME}/.config/mihomo/backups`;
  const listBackups = () => {
    if (!fs.existsSync(backupsDir)) return [];
    return fs.readdirSync(backupsDir)
      .filter(f => fs.statSync(`${backupsDir}/${f}`).isDirectory())
      .sort();
  };

  if (!dir) {
    const list = listBackups().reverse();
    if (list.length === 0) {
      console.log(c.dim('\n  无可用备份，先运行: mihomo-ctl backup'));
      return;
    }
    console.log(c.bold('\n── 可用备份 ──────────────────────────────────'));
    list.slice(0, 10).forEach((b, i) => {
      const files = fs.readdirSync(`${backupsDir}/${b}`).join(', ');
      console.log(`  ${i === 0 ? c.green('[最新]') : '      '} ${b}  ${c.dim(files)}`);
    });
    console.log(c.dim('\n  恢复最新: mihomo-ctl restore latest'));
    console.log(c.dim('  恢复指定: mihomo-ctl restore <时间戳>'));
    return;
  }

  let targetDir;
  if (dir === 'latest') {
    const list = listBackups();
    if (list.length === 0) { console.log(c.red('无可用备份')); return; }
    targetDir = `${backupsDir}/${list[list.length - 1]}`;
  } else {
    targetDir = fs.existsSync(dir) ? dir : `${backupsDir}/${dir}`;
  }
  if (!fs.existsSync(targetDir)) { console.log(c.red(`✗ 找不到备份: ${dir}`)); return; }
  const srcConfig = `${targetDir}/config.yaml`;
  if (!fs.existsSync(srcConfig)) { console.log(c.red('✗ 备份中无 config.yaml')); return; }

  // 先保存当前配置再覆盖
  if (fs.existsSync(CONFIG)) {
    const safeTs  = new Date().toISOString().slice(0, 19).replace(/[T:]/g, '-');
    const safeDir = `${backupsDir}/pre-restore-${safeTs}`;
    fs.mkdirSync(safeDir, { recursive: true });
    fs.copyFileSync(CONFIG, `${safeDir}/config.yaml`);
    console.log(c.dim(`  当前配置已另存: ${safeDir}/config.yaml`));
  }
  fs.copyFileSync(srcConfig, CONFIG);
  const label = targetDir.startsWith(backupsDir) ? targetDir.slice(backupsDir.length + 1) : targetDir;
  console.log(c.green(`\n  ✓ 已从 [${label}] 恢复配置`));
  console.log(c.dim('  热重载: mihomo-ctl reload'));
}

