async function cmdProxyOff() {
  if (!P.supportsProxy) {
    console.log(c.yellow('⚠ proxy-off 仅支持 macOS / Linux / FreeBSD / Alpine / Windows'));
    return;
  }
  let iface = P.getActiveInterface(), oldGitHttpProxy = '', oldGitHttpsProxy = '';
  try {
    const bak = JSON.parse(fs.readFileSync(PROXY_BACKUP_FILE, 'utf8'));
    iface            = bak.iface || bak.service || (Array.isArray(bak.services) && bak.services[0]) || iface;
    oldGitHttpProxy  = bak.oldGitHttpProxy  || '';
    oldGitHttpsProxy = bak.oldGitHttpsProxy || '';
  } catch {}
  try { P.clearSystemProxy(iface); } catch {}
  if (P.hasGit()) {
    if (oldGitHttpProxy)  run(`git config --global http.proxy  "${oldGitHttpProxy}"`);
    else                  run(`git config --global --unset http.proxy  ${P.gitNull}`);
    if (oldGitHttpsProxy) run(`git config --global https.proxy "${oldGitHttpsProxy}"`);
    else                  run(`git config --global --unset https.proxy ${P.gitNull}`);
  }
  try { fs.unlinkSync(PROXY_BACKUP_FILE); } catch {}
  if (['linux', 'alpine', 'freebsd'].includes(P.name)) {
    console.log(c.green('✓ 系统代理已关闭（rc 文件代理变量已移除）'));
    console.log(c.dim('  当前终端立即清除: ') + c.cyan('eval $(mihomo-ctl proxy-env)'));
  } else {
    console.log(c.green('✓ 系统代理已关闭'));
  }
}

