  ? path.join(process.env.APPDATA || os.homedir(), 'mihomo')
  : path.join(os.homedir(), '.config', 'mihomo');

const PLIST  = `${os.homedir()}/Library/LaunchAgents/io.github.metacubex.mihomo.plist`;
