async function cmdTest() {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }
  console.log(c.bold('\n── 测速所有节点 ──────────────────────────────'));
  console.log(c.dim('  正在触发测速（约 10s）...\n'));

  // 逐个测速
  const data  = await apiGet('/proxies');
  const names = Object.entries(data.proxies || {})
    .filter(([, v]) => !['Selector','URLTest','Fallback','LoadBalance','Direct','Reject'].includes(v.type)
                    && !['DIRECT','REJECT','GLOBAL'].includes(v.name))
    .map(([n]) => n);

  const tested = await Promise.all(names.map(name =>
    new Promise(resolve => {
      const opts = {
        hostname: '127.0.0.1', port: 9090,
        path: `/proxies/${encodeURIComponent(name)}/delay?url=https%3A%2F%2Fwww.gstatic.com%2Fgenerate_204&timeout=5000`,
        method: 'GET', timeout: 8000,
      };
      const req = http.request(opts, res => {
        let d = '';
        res.on('data', c => d += c);
        res.on('end', () => {
          try { resolve({ name, ...JSON.parse(d) }); }
          catch { resolve({ name, delay: 0 }); }
        });
      });
      req.on('error', () => resolve({ name, delay: 0 }));
      req.on('timeout', () => { req.destroy(); resolve({ name, delay: 0 }); });
      req.end();
    })
  ));

  tested.sort((a, b) => (a.delay || 99999) - (b.delay || 99999));
  for (const { name, delay } of tested) {
    const ping = delay ? c.green(`${delay}ms`.padStart(7)) : c.red('  超时');
    console.log(`  ${ping}  ${name}`);
  }
}

// ─── 交互式选择 ────────────────────────────────────────────────
function interactiveSelect(items, prompt) {
  return new Promise(resolve => {
    const readline = require('readline');
    let idx = 0;

    const rl = readline.createInterface({ input: process.stdin });
    process.stdin.setRawMode(true);
    readline.emitKeypressEvents(process.stdin);

    function render() {
      // 清除已渲染的行
      process.stdout.write(`\x1b[${items.length + 1}A`);
      console.log(c.dim(prompt));
      items.forEach((item, i) => {
        const selected = i === idx;
        const prefix = selected ? c.cyan(' ❯ ') : '   ';
        const label  = selected ? c.bold(c.cyan(item.label)) : item.label;
        const sub    = item.sub ? c.dim(`  ${item.sub}`) : '';
        console.log(`${prefix}${label}${sub}`);
      });
    }

    // 初次渲染（先打印空行占位）
    console.log(c.dim(prompt));
    items.forEach(() => console.log(''));
    render();

    process.stdin.on('keypress', (str, key) => {
      if (!key) return;
      if (key.name === 'up')   { idx = (idx - 1 + items.length) % items.length; render(); }
      if (key.name === 'down') { idx = (idx + 1) % items.length; render(); }
      if (key.name === 'return') {
        process.stdin.setRawMode(false);
        rl.close();
        process.stdin.removeAllListeners('keypress');
        console.log('');
        resolve(items[idx]);
      }
      if (key.name === 'escape' || (key.ctrl && key.name === 'c')) {
        process.stdin.setRawMode(false);
        rl.close();
        process.stdin.removeAllListeners('keypress');
        console.log('');
        resolve(null);
      }
    });
  });
}

// ─── 命令：select ──────────────────────────────────────────────
async function cmdSelect(group, node) {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }

  // 直接命令行模式（有参数）
  if (group && node) {
    const res = await apiPut(`/proxies/${encodeURIComponent(group)}`, { name: node });
    if (res.status === 204) console.log(c.green(`✓ 已切换 [${group}] → ${node}`));
    else console.log(c.red(`✗ 失败 ${res.status}: ${res.body}`));
    return;
  }

  // 交互模式
  const data = await apiGet('/proxies');
  const proxies = data.proxies || {};

  // 第一步：选择组（Selector 类型）
  const groups = Object.entries(proxies)
    .filter(([, v]) => v.type === 'Selector')
    .map(([name, v]) => ({ label: name, sub: `当前: ${v.now || '—'}`, value: name, all: v.all || [] }));

  if (!groups.length) { console.log(c.red('没有可切换的 Selector 组')); return; }

  console.log(c.bold('\n── 交互切换节点 ─────────────────── ↑↓选择 Enter确认 Esc退出\n'));
  const chosenGroup = await interactiveSelect(groups, '第一步：选择代理组');
  if (!chosenGroup) { console.log(c.dim('已取消')); return; }

  // 第二步：选择节点
  const nodes = chosenGroup.all.map(n => {
    const p = proxies[n];
    const delay = p?.history?.slice(-1)[0]?.delay;
    const ping  = delay ? `${delay}ms` : '—';
    const type  = p?.type || '';
    return { label: n, sub: `${type}  ${ping}`, value: n };
  });

  const chosenNode = await interactiveSelect(nodes, `第二步：选择节点  (组: ${chosenGroup.label})`);
  if (!chosenNode) { console.log(c.dim('已取消')); return; }

  const res = await apiPut(`/proxies/${encodeURIComponent(chosenGroup.value)}`, { name: chosenNode.value });
  if (res.status === 204) console.log(c.green(`✓ 已切换 [${chosenGroup.label}] → ${chosenNode.label}`));
  else console.log(c.red(`✗ 失败 ${res.status}: ${res.body}`));
}

