      console.log(c.dim('✓ 已禁用开机自启（当前进程不受影响）'));
    },

    // ── 系统代理 ──────────────────────────────────────────────
    getCurlProxyArg() {
      try {
        const out     = run('reg query "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyServer');
        const enabled = run('reg query "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyEnable');
        if (enabled.includes('0x1')) {
          const m = out.match(/ProxyServer\s+REG_SZ\s+(\S+)/);
          if (m) return `-x "http://${m[1]}"`;
        }
      } catch {}
      return '';
    },
    isSystemProxyActive() {
      const out = run('reg query "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyEnable 2>nul');
      const srv = run('reg query "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyServer 2>nul');
      return out.includes('0x1') && srv.includes('127.0.0.1');
    },
    getActiveInterface() {
      return run('powershell -NoProfile -Command "(Get-NetRoute -DestinationPrefix 0.0.0.0/0 | Sort-Object RouteMetric | Select-Object -First 1).InterfaceAlias"').trim() || 'Wi-Fi';
    },
    setSystemProxy(_iface) {
      execSync('reg add "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyEnable /t REG_DWORD /d 1 /f', { stdio: 'pipe' });
      execSync('reg add "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyServer /t REG_SZ /d "127.0.0.1:7890" /f', { stdio: 'pipe' });
    },
    clearSystemProxy(_iface) {
      run('reg add "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings" /v ProxyEnable /t REG_DWORD /d 0 /f');
    },
    proxySuccessMsg(_iface) { return '✓ 系统代理已接管 → 127.0.0.1:7890 (Windows 注册表)'; },

    // ── DNS ──────────────────────────────────────────────────
    checkDns1053()  { return true; }, // Windows 跳过前置检查，由 netsh 实际操作验证
    getDnsServers(iface) {
      const out = run(`powershell -NoProfile -Command "(Get-DnsClientServerAddress -InterfaceAlias '${iface}' -AddressFamily IPv4).ServerAddresses -join ','"`);
      return out.trim() ? out.trim().split(',').map(s => s.trim()).filter(Boolean) : [];
    },
    setDnsToMihomo(iface) {
      execSync(`netsh interface ip set dns "${iface}" static 127.0.0.1`, { stdio: 'pipe' });
    },
    async restoreAll(iface, dnsToRestore) {
      if (dnsToRestore && dnsToRestore.length) {
        execSync(`netsh interface ip set dns "${iface}" static ${dnsToRestore[0]}`, { stdio: 'pipe' });
        for (let i = 1; i < dnsToRestore.length; i++)
          run(`netsh interface ip add dns "${iface}" ${dnsToRestore[i]} index=${i + 1}`);
      } else {
        execSync(`netsh interface ip set dns "${iface}" dhcp`, { stdio: 'pipe' });
      }
      run('ipconfig /flushdns 2>nul || true');
      return dnsToRestore?.length ? dnsToRestore.join(', ') : 'DHCP 自动';
    },
    flushDns()         { run('ipconfig /flushdns 2>nul || true'); },
    isDnsActive(iface) { return this.getDnsServers(iface).includes('127.0.0.1'); },
    loadPfAnchor()     { /* no-op on Windows */ },
    isPfAnchorActive() { return false; },
    printDnsStatus(iface) {
      const servers     = this.getDnsServers(iface);
      const mihomoIsDns = servers.includes('127.0.0.1');
      const port1053    = !!run('netstat -ano 2>nul | findstr ":1053"');
      console.log(`  接口       : ${c.cyan(iface)}`);
      console.log(`  系统 DNS   : ${mihomoIsDns ? c.cyan('127.0.0.1') : c.dim('(DHCP / 其他)')}`);
      console.log(`  Mihomo 监听 1053 : ${port1053 ? c.green('✓') : c.red('✗')}`);
      console.log(`  接管状态 : ${(mihomoIsDns && port1053) ? c.green('已接管') : c.dim('未接管')}`);
    },
    adminHint() { console.log(c.dim('  请以管理员身份运行')); },
    dnsOnSuccess(iface) {
      console.log(c.green(`✓ DNS 已接管 → 127.0.0.1 (接口: ${iface})`));
      console.log(c.dim('  关闭: mihomo-ctl dns-off'));
    },
    dnsOnErrorHint(_iface) { this.adminHint(); },

    // ── 升级 ─────────────────────────────────────────────────
    upgradeAsset(osName, arch, latest) {
      const unzipDir = path.join(TMP, `mihomo-new-${latest}`);
      return {
        url:      `https://github.com/MetaCubeX/mihomo/releases/download/${latest}/mihomo-${osName}-${arch}-${latest}.zip`,
        tmpPkg:   path.join(TMP, `mihomo-new-${latest}.zip`),
        tmpBin:   path.join(unzipDir, `mihomo-${osName}-${arch}-${latest}.exe`),
        bkBin:    path.join(TMP, `mihomo-old-${latest}.exe`),
        unzipDir,
      };
    },
    extractAsset(tmpPkg, tmpBin, extra) {
      const dir = extra?.unzipDir || path.dirname(tmpBin);
      fs.mkdirSync(dir, { recursive: true });
      execSync(`powershell -Command "Expand-Archive -Path '${tmpPkg}' -DestinationPath '${dir}' -Force"`, { stdio: 'pipe' });
      const exeFiles = fs.readdirSync(dir).filter(f => f.endsWith('.exe'));
      if (!exeFiles.length) throw new Error('解压后未找到 .exe 文件');
      const actual = path.join(dir, exeFiles[0]);
      if (actual !== tmpBin) fs.renameSync(actual, tmpBin);
    },
    installBin(tmpBin)  { fs.copyFileSync(tmpBin, BIN); },
    backupBin(bkBin)    { if (fs.existsSync(BIN)) try { fs.copyFileSync(BIN, bkBin); } catch {} },
    rollbackBin(bkBin)  { if (fs.existsSync(bkBin)) try { fs.copyFileSync(bkBin, BIN); } catch {} },
    upgradeRollbackHint(bkBin) { return `copy "${bkBin}" "${BIN}" && mihomo-ctl restart`; },
    installSelf(tmp, self, bak) {
      fs.copyFileSync(self, bak);
      fs.copyFileSync(tmp, self);
      try { fs.unlinkSync(tmp); } catch {}
    },
    selfRollbackHint(bak, self) { return `copy "${bak}" "${self}"`; },
  },
};

// ── Linux/FreeBSD rc 文件代理管理 ─────────────────────────────
const RC_MARKER_BEGIN  = '# >>> mihomo proxy <<<';
const RC_MARKER_END    = '# <<< mihomo proxy >>>';
const PROXY_ENV_URL    = 'http://127.0.0.1:7890';
const SOCKS_ENV_URL    = 'socks5://127.0.0.1:7891';
const NO_PROXY_LIST    = 'localhost,127.0.0.1,::1';

function getShellRcFiles() {
  const isCsh = (process.env.SHELL || '').toLowerCase().includes('csh');
  const names = isCsh ? ['.cshrc', '.tcshrc'] : ['.bashrc', '.bash_profile', '.zshrc', '.profile'];
  const HOME  = os.homedir();
  const found = names.map(n => ({ path: path.join(HOME, n), isCsh })).filter(f => fs.existsSync(f.path));
  if (!found.length) found.push({ path: path.join(HOME, isCsh ? '.cshrc' : '.bashrc'), isCsh });
  return found;
}

function rcProxyBlock(isCsh) {
  const lines = isCsh ? [
    RC_MARKER_BEGIN,
    `setenv http_proxy  ${PROXY_ENV_URL}`,
    `setenv https_proxy ${PROXY_ENV_URL}`,
    `setenv HTTP_PROXY  ${PROXY_ENV_URL}`,
    `setenv HTTPS_PROXY ${PROXY_ENV_URL}`,
    `setenv all_proxy   ${SOCKS_ENV_URL}`,
    `setenv ALL_PROXY   ${SOCKS_ENV_URL}`,
    `setenv no_proxy    ${NO_PROXY_LIST}`,
    RC_MARKER_END,
  ] : [
    RC_MARKER_BEGIN,
    `export http_proxy=${PROXY_ENV_URL}`,
    `export https_proxy=${PROXY_ENV_URL}`,
    `export HTTP_PROXY=${PROXY_ENV_URL}`,
    `export HTTPS_PROXY=${PROXY_ENV_URL}`,
    `export all_proxy=${SOCKS_ENV_URL}`,
    `export ALL_PROXY=${SOCKS_ENV_URL}`,
    `export no_proxy=${NO_PROXY_LIST}`,
    RC_MARKER_END,
  ];
  return lines.join('\n');
}

function rcHasBlock(txt) { return txt.includes(RC_MARKER_BEGIN); }

function rcAddBlock(txt, isCsh) {
  return rcHasBlock(txt) ? txt : txt.trimEnd() + '\n\n' + rcProxyBlock(isCsh) + '\n';
}

function rcRemoveBlock(txt) {
  const [bEsc, eEsc] = [RC_MARKER_BEGIN, RC_MARKER_END].map(s => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
  return txt.replace(new RegExp(`\\n?${bEsc}[\\s\\S]*?${eEsc}\\n?`, 'g'), '\n').replace(/\n{3,}/g, '\n\n').trimEnd() + '\n';
}

function linuxProxyWriteRc() {
  const backupDir = path.join(CONFIG_DIR, 'proxy-rc-backup');
  fs.mkdirSync(backupDir, { recursive: true });
  for (const { path: f, isCsh } of getShellRcFiles()) {
    const existing = fs.existsSync(f) ? fs.readFileSync(f, 'utf8') : '';
    fs.writeFileSync(path.join(backupDir, path.basename(f) + '.bak'), existing);
    fs.writeFileSync(f, rcAddBlock(existing, isCsh));
  }
}

function linuxProxyClearRc() {
  for (const { path: f } of getShellRcFiles()) {
    if (!fs.existsSync(f)) continue;
    const txt = fs.readFileSync(f, 'utf8');
    if (rcHasBlock(txt)) fs.writeFileSync(f, rcRemoveBlock(txt));
  }
}

function linuxRcProxyActive() {
  for (const { path: f } of getShellRcFiles())
    if (fs.existsSync(f) && rcHasBlock(fs.readFileSync(f, 'utf8'))) return true;
  return !!(process.env.https_proxy || process.env.HTTPS_PROXY);
}

// 输出可 eval 的代理语句（无 ANSI 颜色，供 eval $(mihomo-ctl proxy-env) 使用）
function linuxProxyEvalLines(on) {
  const isCsh = (process.env.SHELL || '').toLowerCase().includes('csh');
  const vars  = ['http_proxy','https_proxy','HTTP_PROXY','HTTPS_PROXY','all_proxy','ALL_PROXY','no_proxy'];
  if (!on) return isCsh ? vars.map(v => `unsetenv ${v}`).join('\n') : vars.map(v => `unset ${v}`).join('\n');
  return rcProxyBlock(isCsh).split('\n').filter(l => !l.startsWith('#')).join('\n');
}

// Linux/Alpine 扩展适配器工厂：继承通用适配器，叠加 iptables DNS 接管
function createLinuxAdapter(name, stopCmd, startCmd) {
  return {
    ...createServiceAdapter(name, stopCmd, startCmd),
    supportsDns:  true,
    supportsProxy: true,
    setSystemProxy(_iface)   { linuxProxyWriteRc(); },
    clearSystemProxy(_iface) { linuxProxyClearRc(); },
    isSystemProxyActive()    { return linuxRcProxyActive(); },
    proxySuccessMsg(_iface) {
      const files = getShellRcFiles().map(f => f.path.replace(os.homedir(), '~'));
      return `✓ 代理环境变量已写入 rc 文件: ${files.join(', ')}`;
    },

    // ── 网络接口检测（优先 ip route）────────────────────────────
    getActiveInterface() {
      return run("ip route show default 2>/dev/null | awk 'NR==1{for(i=1;i<=NF;i++) if($i==\"dev\") print $(i+1)}'") || 'default';
    },

    // ── iptables DNS 重定向（53 → 1053）─────────────────────────
    checkDns1053() {
      return !!run('ss -ulnp 2>/dev/null | grep :1053 || lsof -i UDP:1053 -n -P 2>/dev/null | grep -i mihomo');
    },
    getDnsServers(_iface) {
      const out = run("awk '/^nameserver/{print $2}' /etc/resolv.conf 2>/dev/null");
      return out ? out.split('\n').filter(Boolean) : [];
    },
    setDnsToMihomo(_iface) { /* 由 loadPfAnchor 处理，无需改 resolv.conf */ },
    loadPfAnchor() {
      run('sudo iptables -t nat -C OUTPUT -p udp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053 2>/dev/null || sudo iptables -t nat -A OUTPUT -p udp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053');
      run('sudo iptables -t nat -C OUTPUT -p tcp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053 2>/dev/null || sudo iptables -t nat -A OUTPUT -p tcp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053');
      if (!this.isDnsActive()) throw new Error('iptables 规则加载后验证失败');
    },
    isPfAnchorActive() { return this.isDnsActive(); },
    async restoreAll(_iface, _dns) {
      run('sudo iptables -t nat -D OUTPUT -p udp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053 2>/dev/null || true');
      run('sudo iptables -t nat -D OUTPUT -p tcp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053 2>/dev/null || true');
      return '系统默认（iptables 重定向已移除）';
    },
    flushDns() { run('resolvectl flush-caches 2>/dev/null || nscd -K 2>/dev/null || true'); },
    isDnsActive(_iface) {
      return !!run('sudo iptables -t nat -L OUTPUT -n 2>/dev/null | grep REDIRECT | grep 1053');
    },
    printDnsStatus(_iface) {
      const active   = this.isDnsActive();
      const port1053 = this.checkDns1053();
      const dns      = this.getDnsServers();
      console.log(`  系统 DNS (resolv.conf) : ${c.cyan(dns.length ? dns.join(', ') : '(未知)')}`);
      console.log(`  iptables 53→1053       : ${active ? c.green('✓ 已加载') : c.red('✗ 未加载')}`);
      console.log(`  Mihomo 监听 1053       : ${port1053 ? c.green('✓') : c.red('✗')}`);
      if (active && port1053) console.log(`  接管状态 : ${c.green('已接管（iptables 重定向）')}`);
      else                    console.log(`  接管状态 : ${c.dim('未接管')}`);
    },
    adminHint() { console.log(c.dim('  需要 sudo 权限（或在 sudoers 中免密授权 iptables）')); },
    dnsOnSuccess(_iface) {
      console.log(c.green('✓ DNS 已接管 → iptables 53→1053 (Mihomo)'));
      console.log(c.dim('  所有 DNS 请求将通过 Mihomo 路由'));
      console.log(c.dim('  关闭: mihomo-ctl dns-off'));
    },
    dnsOnErrorHint(_iface) {
      this.adminHint();
      console.log(c.cyan('  sudo iptables -t nat -A OUTPUT -p udp ! -d 127.0.0.1 --dport 53 -j REDIRECT --to-ports 1053'));
    },
  };
}

