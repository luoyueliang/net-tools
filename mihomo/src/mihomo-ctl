#!/usr/bin/env node
// mihomo-ctl - Mihomo 管理工具
// 用法: mihomo-ctl [status|start|stop|restart|proxies|test|log|help]

const { execSync, exec } = require('child_process');
const http = require('http');

const API    = 'http://127.0.0.1:9090';
const PLIST  = `${process.env.HOME}/Library/LaunchAgents/io.github.metacubex.mihomo.plist`;
const PLIST_DISABLED = `${process.env.HOME}/Library/LaunchAgents/io.github.metacubex.mihomo.plist.disabled`;
const LOG      = `${process.env.HOME}/.config/mihomo/logs/mihomo.log`;
const CONFIG   = `${process.env.HOME}/.config/mihomo/config.yaml`;
const BIN      = '/usr/local/bin/mihomo';
const DATA_DIR = `${process.env.HOME}/.config/mihomo/data`;
const UI_DIR   = `${process.env.HOME}/.config/mihomo/ui`;
const GEO_CRON_TAG = '# mihomo-geo-update';

// ANSI 颜色
const c = {
  green: s => `\x1b[32m${s}\x1b[0m`,
  red:   s => `\x1b[31m${s}\x1b[0m`,
  yellow:s => `\x1b[33m${s}\x1b[0m`,
  cyan:  s => `\x1b[36m${s}\x1b[0m`,
  bold:  s => `\x1b[1m${s}\x1b[0m`,
  dim:   s => `\x1b[2m${s}\x1b[0m`,
};

function apiGet(path) {
  return new Promise((resolve, reject) => {
    const req = http.get(`${API}${path}`, { timeout: 3000 }, res => {
      let data = '';
      res.on('data', d => data += d);
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch { resolve(data); }
      });
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
  });
}

function apiPut(path, body) {
  return new Promise((resolve, reject) => {
    const data = JSON.stringify(body);
    const opts = {
      hostname: '127.0.0.1', port: 9090, path, method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) },
      timeout: 3000,
    };
    const req = http.request(opts, res => {
      let d = '';
      res.on('data', c => d += c);
      res.on('end', () => resolve({ status: res.statusCode, body: d }));
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
    req.write(data);
    req.end();
  });
}

function run(cmd) {
  try { return execSync(cmd, { encoding: 'utf8' }).trim(); }
  catch { return ''; }
}

async function isRunning() {
  try { await apiGet('/version'); return true; }
  catch { return false; }
}

// ─── 平台检测 & 服务管理 ──────────────────────────────────────
function detectPlatform() {
  const fs = require('fs');
  if (process.platform === 'darwin') return 'macos';
  if (fs.existsSync('/etc/alpine-release'))  return 'alpine';
  if (fs.existsSync('/etc/openwrt_release')) return 'openwrt';
  if (process.platform === 'linux')   return 'linux';
  if (process.platform === 'freebsd') return 'freebsd';
  return 'unknown';
}

// 停止 Mihomo 服务（跨平台）
function serviceStop() {
  const pl = detectPlatform();
  if (pl === 'macos') {
    run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
    run(`pkill -f 'mihomo -d' 2>/dev/null || true`);
  } else if (pl === 'linux') {
    run('sudo systemctl stop mihomo 2>/dev/null || true');
  } else if (pl === 'alpine') {
    run('rc-service mihomo stop 2>/dev/null || true');
  } else if (pl === 'openwrt') {
    run('/etc/init.d/mihomo stop 2>/dev/null || true');
  } else if (pl === 'freebsd') {
    run('sudo service mihomo stop 2>/dev/null || true');
  } else {
    run(`pkill -f 'mihomo -d' 2>/dev/null || true`);
  }
}

// 启动 Mihomo 服务（跨平台）
function serviceStart() {
  const fs = require('fs');
  const pl = detectPlatform();
  const HOME = process.env.HOME;
  if (pl === 'macos') {
    if (fs.existsSync(PLIST)) run(`launchctl load "${PLIST}" 2>/dev/null || true`);
    else exec(`${BIN} -d "${HOME}/.config/mihomo" >> "${LOG}" 2>&1 &`);
  } else if (pl === 'linux') {
    run('sudo systemctl start mihomo 2>/dev/null || true');
  } else if (pl === 'alpine') {
    run('rc-service mihomo start 2>/dev/null || true');
  } else if (pl === 'openwrt') {
    run('/etc/init.d/mihomo start 2>/dev/null || true');
  } else if (pl === 'freebsd') {
    run('sudo service mihomo start 2>/dev/null || true');
  } else {
    exec(`${BIN} -d "${HOME}/.config/mihomo" >> "${LOG}" 2>&1 &`);
  }
}

// ─── 命令：status ──────────────────────────────────────────────
async function cmdStatus() {
  console.log(c.bold('\n── Mihomo 状态 ──────────────────────────────'));

  // 开机自启状态
  const fs = require('fs');
  const autostartOn  = fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED);
  const autostartOff = fs.existsSync(PLIST_DISABLED);
  const autostartStr = autostartOn ? c.green('开机自启: 已启用') : c.dim('开机自启: 已禁用');

  const running = await isRunning();
  if (!running) {
    console.log(c.red('● 未运行') + `   ${autostartStr}`);
    const launchd = run('launchctl list | grep mihomo');
    if (launchd) console.log(c.yellow('  LaunchAgent 已加载但进程未响应 API'));
    return;
  }

  // 版本
  const ver = await apiGet('/version');
  console.log(c.green('● 运行中') + `  版本: ${ver.version || '?'}   ${autostartStr}`);

  // PID & 端口
  const pid = run("pgrep -f 'mihomo -d'");
  const port7890 = run('lsof -i :7890 -sTCP:LISTEN -n | grep mihomo | head -1');
  console.log(`  PID: ${pid || '?'}   端口: ${port7890 ? c.green('7890 ✓') : c.red('7890 ✗')}  管理: 9090`);

  // 当前模式 & 日志 & DNS
  const cfg = await apiGet('/configs').catch(() => ({}));
  const logLevel = cfg['log-level'] || '?';
  const logStr   = logLevel === 'silent' ? c.dim('日志: 关闭') : c.yellow(`日志: ${logLevel}`);
  const dnsStr   = isDnsManagedByMihomo() ? c.green('DNS: 已接管') : c.dim('DNS: 系统默认');
  const proxyStr   = isSystemProxySetToMihomo() ? c.green('代理: 已接管') : c.dim('代理: 系统默认');
  console.log(`  模式: ${c.cyan(cfg.mode || '?')}   ${logStr}   ${dnsStr}   ${proxyStr}`);

  // 当前出口
  const groups = await apiGet('/proxies').catch(() => ({}));
  const main = groups?.proxies?.['\u{1F30D} 默认出口'];
  if (main?.now) console.log(`  默认出口: ${c.cyan(main.now)}`);
  const auto = groups?.proxies?.['\u{1F680} 自动选择'];
  if (auto?.now) console.log(`  自动选择: ${c.cyan(auto.now)}`);

  // 连接数 & 累计流量
  const conns = await apiGet('/connections').catch(() => ({}));
  const connCount = (conns.connections || []).length;
  const { downloadTotal = 0, uploadTotal = 0 } = conns;
  const fmtB = b => b > 1e9 ? `${(b/1e9).toFixed(2)}GB` : b > 1e6 ? `${(b/1e6).toFixed(1)}MB` : b > 1e3 ? `${(b/1e3).toFixed(0)}KB` : `${b}B`;
  console.log(`  连接数: ${c.cyan(connCount)}   流量: \u2193${c.cyan(fmtB(downloadTotal))} \u2191${c.yellow(fmtB(uploadTotal))}`);

  // GeoIP 文件新鲜度
  const geoipPath = `${DATA_DIR}/geoip.dat`;
  if (fs.existsSync(geoipPath)) {
    const days = Math.floor((Date.now() - fs.statSync(geoipPath).mtimeMs) / 86400000);
    const ageStr = days === 0 ? '今天' : `${days} 天前`;
    console.log(`  GeoIP: ${days > 30 ? c.yellow('更新于 ' + ageStr + '  建议: mihomo-ctl geo update') : c.dim('更新于 ' + ageStr)}`);
  } else {
    console.log(c.dim('  GeoIP: 未下载   mihomo-ctl geo update'));
  }
}
async function cmdProxies() {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }
  const data = await apiGet('/proxies');
  const proxies = data.proxies || {};

  console.log(c.bold('\n── 代理节点 ──────────────────────────────────'));
  for (const [name, info] of Object.entries(proxies)) {
    if (['DIRECT','REJECT','GLOBAL'].includes(name)) continue;
    if (info.type === 'Selector' || info.type === 'URLTest' || info.type === 'Fallback') {
      const alive = (info.all || []).filter(n => proxies[n]?.history?.slice(-1)[0]?.delay > 0);
      const now   = info.now ? c.green(info.now) : c.dim('未选择');
      console.log(`\n  ${c.bold(c.cyan(name))} [${info.type}]  当前: ${now}`);
      for (const sub of (info.all || [])) {
        const p = proxies[sub];
        if (!p) continue;
        const delay = p.history?.slice(-1)[0]?.delay;
        const ping  = delay ? c.green(`${delay}ms`) : c.dim('未测速');
        const mark  = info.now === sub ? ' ◀' : '';
        console.log(`    ${c.dim('·')} ${sub.padEnd(30)} ${ping}${mark}`);
      }
    } else if (!['Selector','URLTest','Fallback','LoadBalance'].includes(info.type)) {
      const delay = info.history?.slice(-1)[0]?.delay;
      const ping  = delay ? c.green(`${delay}ms`) : c.dim('—');
      console.log(`  ${name.padEnd(32)} ${String(info.type).padEnd(12)} ${ping}`);
    }
  }
}

// ─── 命令：test ────────────────────────────────────────────────
async function cmdTest() {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }
  console.log(c.bold('\n── 测速所有节点 ──────────────────────────────'));
  console.log(c.dim('  正在触发测速（约 10s）...\n'));

  // 逐个测速
  const data  = await apiGet('/proxies');
  const names = Object.entries(data.proxies || {})
    .filter(([, v]) => !['Selector','URLTest','Fallback','LoadBalance','Direct','Reject'].includes(v.type)
                    && !['DIRECT','REJECT','GLOBAL'].includes(v.name))
    .map(([n]) => n);

  const tested = await Promise.all(names.map(name =>
    new Promise(resolve => {
      const opts = {
        hostname: '127.0.0.1', port: 9090,
        path: `/proxies/${encodeURIComponent(name)}/delay?url=https%3A%2F%2Fwww.gstatic.com%2Fgenerate_204&timeout=5000`,
        method: 'GET', timeout: 8000,
      };
      const req = http.request(opts, res => {
        let d = '';
        res.on('data', c => d += c);
        res.on('end', () => {
          try { resolve({ name, ...JSON.parse(d) }); }
          catch { resolve({ name, delay: 0 }); }
        });
      });
      req.on('error', () => resolve({ name, delay: 0 }));
      req.on('timeout', () => { req.destroy(); resolve({ name, delay: 0 }); });
      req.end();
    })
  ));

  tested.sort((a, b) => (a.delay || 99999) - (b.delay || 99999));
  for (const { name, delay } of tested) {
    const ping = delay ? c.green(`${delay}ms`.padStart(7)) : c.red('  超时');
    console.log(`  ${ping}  ${name}`);
  }
}

// ─── 交互式选择 ────────────────────────────────────────────────
function interactiveSelect(items, prompt) {
  return new Promise(resolve => {
    const readline = require('readline');
    let idx = 0;

    const rl = readline.createInterface({ input: process.stdin });
    process.stdin.setRawMode(true);
    readline.emitKeypressEvents(process.stdin);

    function render() {
      // 清除已渲染的行
      process.stdout.write(`\x1b[${items.length + 1}A`);
      console.log(c.dim(prompt));
      items.forEach((item, i) => {
        const selected = i === idx;
        const prefix = selected ? c.cyan(' ❯ ') : '   ';
        const label  = selected ? c.bold(c.cyan(item.label)) : item.label;
        const sub    = item.sub ? c.dim(`  ${item.sub}`) : '';
        console.log(`${prefix}${label}${sub}`);
      });
    }

    // 初次渲染（先打印空行占位）
    console.log(c.dim(prompt));
    items.forEach(() => console.log(''));
    render();

    process.stdin.on('keypress', (str, key) => {
      if (!key) return;
      if (key.name === 'up')   { idx = (idx - 1 + items.length) % items.length; render(); }
      if (key.name === 'down') { idx = (idx + 1) % items.length; render(); }
      if (key.name === 'return') {
        process.stdin.setRawMode(false);
        rl.close();
        process.stdin.removeAllListeners('keypress');
        console.log('');
        resolve(items[idx]);
      }
      if (key.name === 'escape' || (key.ctrl && key.name === 'c')) {
        process.stdin.setRawMode(false);
        rl.close();
        process.stdin.removeAllListeners('keypress');
        console.log('');
        resolve(null);
      }
    });
  });
}

// ─── 命令：select ──────────────────────────────────────────────
async function cmdSelect(group, node) {
  if (!(await isRunning())) { console.log(c.red('Mihomo 未运行')); return; }

  // 直接命令行模式（有参数）
  if (group && node) {
    const res = await apiPut(`/proxies/${encodeURIComponent(group)}`, { name: node });
    if (res.status === 204) console.log(c.green(`✓ 已切换 [${group}] → ${node}`));
    else console.log(c.red(`✗ 失败 ${res.status}: ${res.body}`));
    return;
  }

  // 交互模式
  const data = await apiGet('/proxies');
  const proxies = data.proxies || {};

  // 第一步：选择组（Selector 类型）
  const groups = Object.entries(proxies)
    .filter(([, v]) => v.type === 'Selector')
    .map(([name, v]) => ({ label: name, sub: `当前: ${v.now || '—'}`, value: name, all: v.all || [] }));

  if (!groups.length) { console.log(c.red('没有可切换的 Selector 组')); return; }

  console.log(c.bold('\n── 交互切换节点 ─────────────────── ↑↓选择 Enter确认 Esc退出\n'));
  const chosenGroup = await interactiveSelect(groups, '第一步：选择代理组');
  if (!chosenGroup) { console.log(c.dim('已取消')); return; }

  // 第二步：选择节点
  const nodes = chosenGroup.all.map(n => {
    const p = proxies[n];
    const delay = p?.history?.slice(-1)[0]?.delay;
    const ping  = delay ? `${delay}ms` : '—';
    const type  = p?.type || '';
    return { label: n, sub: `${type}  ${ping}`, value: n };
  });

  const chosenNode = await interactiveSelect(nodes, `第二步：选择节点  (组: ${chosenGroup.label})`);
  if (!chosenNode) { console.log(c.dim('已取消')); return; }

  const res = await apiPut(`/proxies/${encodeURIComponent(chosenGroup.value)}`, { name: chosenNode.value });
  if (res.status === 204) console.log(c.green(`✓ 已切换 [${chosenGroup.label}] → ${chosenNode.label}`));
  else console.log(c.red(`✗ 失败 ${res.status}: ${res.body}`));
}

function isSystemProxySetToMihomo() {
  const out = run('scutil --proxy 2>/dev/null');
  return out.includes('HTTPProxy : 127.0.0.1') && out.includes('HTTPEnable : 1');
}

function getAllNetworkServices() {
  // 返回所有已启用的网络服务（过滤掉屏条目）
  return run('networksetup -listallnetworkservices 2>/dev/null')
    .split('\n')
    .filter(s => s && !s.startsWith('An ') && !s.includes('*'));
}

async function cmdProxyOn() {
  if (!(await isRunning())) { console.log(c.red('请先启动 Mihomo: mihomo-ctl start')); return; }
  const services = getAllNetworkServices();
  require('fs').writeFileSync(PROXY_BACKUP_FILE, JSON.stringify({ services }));
  let ok = 0, fail = 0;
  for (const svc of services) {
    try {
      execSync(`sudo networksetup -setwebproxy "${svc}" 127.0.0.1 7890 2>/dev/null`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsecurewebproxy "${svc}" 127.0.0.1 7890 2>/dev/null`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsocksfirewallproxy "${svc}" 127.0.0.1 7890 2>/dev/null`, { stdio: ['inherit', 'pipe', 'pipe'] });
      ok++;
    } catch { fail++; }
  }
  console.log(c.green(`✓ 系统代理已接管 → 127.0.0.1:7890 (成功 ${ok} 个服务)` + (fail ? c.dim(` 跳过 ${fail} 个`) : '')));
  console.log(c.dim('  关闭: mihomo-ctl proxy-off'));
}

async function cmdProxyOff() {
  let services;
  try {
    const bak = JSON.parse(require('fs').readFileSync(PROXY_BACKUP_FILE, 'utf8'));
    services = Array.isArray(bak.services) ? bak.services : null;
  } catch {}
  if (!services) services = getAllNetworkServices();
  let ok = 0;
  for (const svc of services) {
    try {
      execSync(`sudo networksetup -setwebproxystate "${svc}" off 2>/dev/null`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsecurewebproxystate "${svc}" off 2>/dev/null`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsocksfirewallproxystate "${svc}" off 2>/dev/null`, { stdio: ['inherit', 'pipe', 'pipe'] });
      ok++;
    } catch {}
  }
  try { require('fs').unlinkSync(PROXY_BACKUP_FILE); } catch {}
  console.log(c.green(`✓ 系统代理已关闭 (共 ${ok} 个服务)`));
}

// ─── 命令：dns-on / dns-off ──────────────────────────────────
const PF_CONF = '/tmp/mihomo-dns.pf.conf';
const PF_TOKEN_FILE = '/tmp/mihomo-dns.pf.token';
const DNS_BACKUP_FILE = '/tmp/mihomo-dns.backup';
const PROXY_BACKUP_FILE = '/tmp/mihomo-proxy.backup';
const DNS_AUTOSTART_FILE = `${process.env.HOME}/.config/mihomo/.dns-autostart`;

function getWifiInterface() {
  // 找第一个活跃的 Wi-Fi 或以太网
  const services = run('networksetup -listallnetworkservices').split('\n').filter(s => !s.startsWith('An '));
  for (const svc of services) {
    const dev = run(`networksetup -getinfo "${svc}" | grep "^IP address:"`);
    if (dev) return svc;
  }
  return 'Wi-Fi';
}

async function cmdDnsOn() {
  if (!(await isRunning())) { console.log(c.red('请先启动 Mihomo: mihomo-ctl start')); return; }

  // 检查 1053 是否在监听
  const listening = run('lsof -i :1053 -sTCP:LISTEN -n -P 2>/dev/null || lsof -i UDP:1053 -n -P 2>/dev/null | grep mihomo');
  if (!listening) {
    console.log(c.red('✗ Mihomo DNS 未在 127.0.0.1:1053 监听，请检查配置后重启'));
    console.log(c.dim('  mihomo-ctl restart'));
    return;
  }

  const iface = getWifiInterface();
  console.log(c.bold(`\n── 开启 DNS 接管 (接口: ${iface}) ─────────────────`));

  // 备份当前 DNS（区分 DHCP 自动 vs 固定 DNS）
  const currentDns = run(`networksetup -getdnsservers "${iface}"`);
  // macOS 无 DNS 时返回 "There aren't any DNS Servers set on ..."
  const isDhcp = !currentDns || currentDns.includes("aren't") || currentDns.includes('127.0.0.1');
  const dnsToRestore = isDhcp ? null : currentDns.trim().split('\n').filter(Boolean);
  require('fs').writeFileSync(DNS_BACKUP_FILE, JSON.stringify({ iface, dnsToRestore }));

  // 写 pf rdr 规则（lo0: 53 → 1053）
  // 使用 com.apple/mihomo-dns 子 anchor，避免覆盖 Apple 自身的 pf 规则
  // macOS pf anchor 内使用 "rdr on" 语法（不带 pass），rdr-to / rdr pass 均不支持
  const pfConf = [
    'rdr on lo0 proto udp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053',
    'rdr on lo0 proto tcp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053',
  ].join('\n') + '\n';
  require('fs').writeFileSync(PF_CONF, pfConf);

  try {
    // 加载进 com.apple 子 anchor（/etc/pf.conf 中有 rdr-anchor "com.apple/*"）
    execSync(`sudo pfctl -a 'com.apple/mihomo-dns' -f "${PF_CONF}"`, { stdio: ['inherit', 'pipe', 'pipe'] });
    // 确保 pf 已启用
    execSync('sudo pfctl -e 2>/dev/null || true', { stdio: 'pipe' });
    // 验证规则已加载
    const loaded = run(`sudo pfctl -a 'com.apple/mihomo-dns' -sn 2>/dev/null`);
    if (!loaded.includes('1053')) throw new Error('pf anchor 规则加载后验证失败');
    // 设置系统 DNS
    execSync(`sudo networksetup -setdnsservers "${iface}" 127.0.0.1`, { stdio: ['inherit', 'pipe', 'pipe'] });
    // networksetup 已自动通知 mDNSResponder，只需刷新应用层缓存（不需要 sudo）
    execSync('dscacheutil -flushcache 2>/dev/null || true', { stdio: 'pipe' });
    require('fs').writeFileSync(DNS_AUTOSTART_FILE, '1');
    console.log(c.green(`✓ DNS 已接管 → 127.0.0.1:1053 (Mihomo DoH)`) );
    console.log(c.dim('  国内域名 → 阿里/腾讯 DoH (直连)'));
    console.log(c.dim('  国外域名 → 1.1.1.1 / Google DoH (走代理)'));
    console.log(c.dim(`\n  关闭: mihomo-ctl dns-off`));
  } catch (e) {
    console.log(c.red(`✗ 失败: ${e.message}`));
    console.log(c.dim('  可能需要 sudo 权限，请手动运行:'));
    console.log(c.cyan(`  sudo pfctl -a 'com.apple/mihomo-dns' -f "${PF_CONF}" && sudo pfctl -e`));
    console.log(c.cyan(`  sudo networksetup -setdnsservers "${iface}" 127.0.0.1`));
  }
}

async function cmdDnsOff() {
  let iface = getWifiInterface();
  let dnsToRestore = null;  // null = DHCP
  try {
    const bak = JSON.parse(require('fs').readFileSync(DNS_BACKUP_FILE, 'utf8'));
    if (bak.iface) iface = bak.iface;
    dnsToRestore = bak.dnsToRestore || null;
  } catch {}

  console.log(c.bold(`\n── 关闭 DNS 接管 (接口: ${iface}) ────────────────`));
  try {
    // ⚠️  顺序至关重要：必须先让系统 DNS 指向一个实际可用的服务器，
    //    否则移除 pf anchor 后会出现"DNS=127.0.0.1 但无人监听"的真空。

    // Step 1: 确定用于过渡的 DNS（优先用备份的固定 DNS，否则探测 DHCP/网关）
    let transitionDns = (dnsToRestore && dnsToRestore.length) ? dnsToRestore : null;
    if (!transitionDns) {
      // 尝试从 DHCP 租约拿 DNS
      const dhcpDns = run(`ipconfig getpacket en0 2>/dev/null | grep domain_name_server | awk '{print $3}' | head -1`).trim()
                   || run(`ipconfig getpacket en1 2>/dev/null | grep domain_name_server | awk '{print $3}' | head -1`).trim();
      if (dhcpDns && dhcpDns.match(/^\d+\.\d+\.\d+\.\d+/)) {
        transitionDns = [dhcpDns.split(',')[0].trim()];
      } else {
        // 回退：用默认网关（通常也是 DNS）
        const gw = run(`netstat -rn | awk '/^default/{print $2; exit}'`).trim();
        transitionDns = (gw && gw.match(/^\d+\.\d+\.\d+\.\d+/)) ? [gw] : ['8.8.8.8'];
      }
    }

    // Step 2: 先把 DNS 切到过渡地址（立即生效，无 DHCP 等待）
    const dnsArgs = transitionDns.map(s => `"${s}"`).join(' ');
    execSync(`sudo networksetup -setdnsservers "${iface}" ${dnsArgs}`, { stdio: 'inherit' });
    // networksetup 会自动通知 mDNSResponder，只需刷新应用层缓存（不需要 sudo）
    execSync('dscacheutil -flushcache 2>/dev/null || true', { stdio: 'pipe' });
    await new Promise(r => setTimeout(r, 600));

    // Step 3: 此时 DNS 已经可用，安全地移除 pf anchor
    // 使用 stdio:'inherit' 确保 sudo 能提示密码，不能静默失败
    execSync(`sudo pfctl -a 'com.apple/mihomo-dns' -F all`, { stdio: 'inherit' });

    // Step 4: 如果原来是 DHCP，最终再设回 Empty 让系统走 DHCP
    if (!dnsToRestore || !dnsToRestore.length) {
      execSync(`sudo networksetup -setdnsservers "${iface}" "Empty"`, { stdio: 'inherit' });
    }

    try { require('fs').unlinkSync(DNS_BACKUP_FILE); } catch {}
    try { require('fs').unlinkSync(PF_CONF); } catch {}
    try { require('fs').unlinkSync(DNS_AUTOSTART_FILE); } catch {}
    const restoredDesc = (dnsToRestore && dnsToRestore.length) ? dnsToRestore.join(', ') : `${transitionDns.join(', ')} (将随 DHCP 更新)`;
    console.log(c.green(`✓ DNS 已恢复为 ${restoredDesc}`));
  } catch (e) {
    console.log(c.red(`✗ 失败: ${e.message}`));
  }
}

async function cmdDnsStatus() {
  const sysDns = run(`scutil --dns | grep 'nameserver\\[0\\]' | head -1`);
  const port1053 = run('lsof -i UDP:1053 -n -P 2>/dev/null | grep mihomo | head -1');
  const anchorRules = run(`sudo pfctl -a 'com.apple/mihomo-dns' -sn 2>/dev/null`);
  const pfAnchorOk = anchorRules.includes('1053');
  console.log(c.bold('\n── DNS 状态 ──────────────────────────────────'));
  console.log(`  系统 DNS : ${c.cyan(sysDns.replace(/.*:/,'').trim() || '?')}`);
  console.log(`  Mihomo 监听 1053 : ${port1053 ? c.green('✓') : c.red('✗')}`);
  console.log(`  pf rdr anchor : ${pfAnchorOk ? c.green('✓ 已加载') : c.red('✗ 未加载')}`);
  const mihomoIsDns = sysDns.includes('127.0.0.1');
  if (pfAnchorOk && mihomoIsDns && port1053) console.log(`  接管状态 : ${c.green('已接管（防污染 DNS 生效）')}`);
  else if (mihomoIsDns && !pfAnchorOk)       console.log(`  接管状态 : ${c.yellow('⚠ 系统 DNS=127.0.0.1 但 pf 规则未加载，运行 dns-on 修复')}`);
  else                                        console.log(`  接管状态 : ${c.dim('未接管（使用默认 DNS）')}`);
  // 快速验证实际解析是否可用
  const canResolve = run('dig +short +time=2 cloudflare.com @127.0.0.1 -p 1053 2>/dev/null');
  console.log(`  实际解析测试 : ${canResolve ? c.green('✓ ' + canResolve.split('\n')[0]) : c.red('✗ 无响应')}`);
  if (!pfAnchorOk && mihomoIsDns) {
    console.log(c.dim('\n  pf anchor 已丢失（常见于睡眠/唤醒或网络切换后），运行:'));
    console.log(c.cyan('  mihomo-ctl dns-on'));
  }
}

// ─── 命令：autostart ──────────────────────────────────────────
function cmdAutostart(action) {
  const fs = require('fs');
  const on  = fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED);
  const off = fs.existsSync(PLIST_DISABLED);

  if (!action) {
    // 显示状态
    console.log(`\n  开机自启: ${on ? c.green('已启用') : c.dim('已禁用')}`);
    console.log(c.dim(`  启用: mihomo-ctl autostart on`));
    console.log(c.dim(`  禁用: mihomo-ctl autostart off`));
    return;
  }

  if (action === 'on') {
    if (off) {
      // 从 disabled 恢复
      fs.renameSync(PLIST_DISABLED, PLIST);
    } else if (!fs.existsSync(PLIST)) {
      console.log(c.red('✗ plist 文件不存在，请重新安装'));
      return;
    }
    run(`launchctl load "${PLIST}" 2>/dev/null || true`);
    console.log(c.green('✓ 已启用开机自启'));
    console.log(c.dim(`  plist: ${PLIST}`));
  } else if (action === 'off') {
    if (on) {
      run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
      fs.renameSync(PLIST, PLIST_DISABLED);
    }
    console.log(c.dim('✓ 已禁用开机自启（当前进程不受影响）'));
    console.log(c.dim(`  plist 已更名为: ${PLIST_DISABLED}`));
  } else {
    console.log('用法: mihomo-ctl autostart [on|off]');
  }
}

// ─── 命令：upgrade ─────────────────────────────────────────────
async function cmdUpgrade() {
  const fs = require('fs');
  const pl = detectPlatform();
  console.log(c.bold('\n── Mihomo 无缝升级 ──────────────────────────'));
  console.log(c.dim(`  平台: ${pl} / ${process.arch === 'arm64' ? 'arm64' : 'amd64'}\n`));

  // 1. 查询最新版本
  process.stdout.write('  查询最新版本... ');
  let latest;
  try {
    const out = run(`curl -sf --max-time 10 "https://api.github.com/repos/MetaCubeX/mihomo/releases/latest"`);
    if (!out) { console.log(c.red('获取失败，检查网络')); return; }
    latest = JSON.parse(out).tag_name;
  } catch (e) { console.log(c.red(`失败: ${e.message}`)); return; }

  const verOut  = run(`"${BIN}" -v 2>/dev/null`);
  const current = (verOut.match(/v[\d]+\.[\d]+\.[\d]+(?:-[a-z0-9]+)?/i) || [])[0] || '';
  console.log(`最新 ${c.green(latest)}  当前 ${current === latest ? c.green(current) : c.yellow(current || '未检测')}`);
  if (current === latest) { console.log(c.green('  已是最新版本')); return; }

  // 2. 构建下载地址
  const osMap  = { darwin: 'darwin', linux: 'linux', freebsd: 'freebsd' };
  const osName = osMap[process.platform] || 'linux';
  const arch   = process.arch === 'arm64' ? 'arm64' : 'amd64';
  const url    = `https://github.com/MetaCubeX/mihomo/releases/download/${latest}/mihomo-${osName}-${arch}-${latest}.gz`;
  const tmpGz  = `/tmp/mihomo-new-${latest}.gz`;
  const tmpBin = `/tmp/mihomo-new-${latest}`;
  const bkBin  = `/tmp/mihomo-old-${current || 'prev'}`;

  // 3. 预下载（进程仍在运行中，最大化在线时间）
  const wasRunning = await isRunning();
  if (wasRunning) console.log(c.green(`  ✓ 进程运行中，预下载中（代理不中断）...`));
  console.log(c.dim(`    ${url}`));
  run(`curl -4 -L -C - --max-time 180 -o "${tmpGz}" "${url}" 2>/dev/null`);
  if (!fs.existsSync(tmpGz) || fs.statSync(tmpGz).size < 500000) {
    console.log(c.red('✗ 下载失败或文件过小，请检查网络'));
    try { fs.unlinkSync(tmpGz); } catch {}
    return;
  }
  run(`gunzip -f "${tmpGz}"`);
  if (!fs.existsSync(tmpBin)) { console.log(c.red('✗ 解压失败')); return; }
  run(`chmod +x "${tmpBin}"`);
  console.log(c.green('  ✓ 下载解压完成'));

  // 4. 自动备份配置（升级前保护）
  const ts        = new Date().toISOString().slice(0, 19).replace(/[T:]/g, '-');
  const backupDir = `${process.env.HOME}/.config/mihomo/backups/${ts}`;
  fs.mkdirSync(backupDir, { recursive: true });
  if (fs.existsSync(CONFIG)) {
    fs.copyFileSync(CONFIG, `${backupDir}/config.yaml`);
    console.log(c.dim(`  配置已备份: ${backupDir}/config.yaml`));
  }

  // 5. 停止服务（停机从这里开始，已下载完，停机时间极短）
  if (wasRunning) {
    process.stdout.write('  停止服务... ');
    serviceStop();
    await new Promise(r => setTimeout(r, 800));
    console.log('done');
  }

  // 6. 备份旧二进制 + 原子替换新二进制
  if (fs.existsSync(BIN)) run(`sudo cp "${BIN}" "${bkBin}" 2>/dev/null`);
  try {
    execSync(`sudo mv "${tmpBin}" "${BIN}"`, { stdio: 'pipe' });
    run(`xattr -d com.apple.quarantine "${BIN}" 2>/dev/null || true`);
  } catch (e) {
    console.log(c.red(`✗ 安装失败: ${e.message}`));
    run(`sudo mv "${bkBin}" "${BIN}" 2>/dev/null || true`);
    console.log(c.yellow('  已回滚旧版本'));
    if (wasRunning) { serviceStart(); await new Promise(r => setTimeout(r, 1500)); }
    return;
  }

  // 7. 启动新版本并验证
  if (wasRunning) {
    process.stdout.write('  启动新版本... ');
    serviceStart();
    await new Promise(r => setTimeout(r, 1800));
    if (await isRunning()) {
      const newOut = run(`"${BIN}" -v 2>/dev/null`);
      const newVer = (newOut.match(/v[\d]+\.[\d]+\.[\d]+(?:-[a-z0-9]+)?/i) || [])[0] || latest;
      console.log(c.green(`\n  ✓ 升级成功: ${current || '?'} → ${newVer}`));
      console.log(c.dim('  代理停机时间: ≈ 3s（预下载完成后才停机）'));
    } else {
      console.log(c.red('\n  ✗ 启动失败，自动回滚...'));
      serviceStop();
      run(`sudo mv "${bkBin}" "${BIN}" 2>/dev/null || true`);
      serviceStart();
      await new Promise(r => setTimeout(r, 1500));
      if (await isRunning()) console.log(c.yellow('  ⚠ 已回滚到旧版本并重启'));
      else console.log(c.red('  ✗ 回滚失败，请手动处理'));
      return;
    }
  } else {
    const newOut = run(`"${BIN}" -v 2>/dev/null`);
    const newVer = (newOut.match(/v[\d]+\.[\d]+\.[\d]+(?:-[a-z0-9]+)?/i) || [])[0] || latest;
    console.log(c.green(`  ✓ 升级完成（当前未运行）: ${current || '?'} → ${newVer}`));
  }

  console.log(c.dim(`  旧二进制: ${bkBin}  配置备份: ${backupDir}/`));
  console.log(c.dim('  如需回滚: sudo mv ' + bkBin + ' ' + BIN + ' && mihomo-ctl restart'));
}


// ─── 命令：log-on / log-off ────────────────────────────────────
function setLogLevel(level) {
  const fs = require('fs');
  let yaml = fs.readFileSync(CONFIG, 'utf8');
  yaml = yaml.replace(/^log-level:.*$/m, `log-level: ${level}`);
  fs.writeFileSync(CONFIG, yaml);
}

