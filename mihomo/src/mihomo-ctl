      if (fs.existsSync(PLIST)) run(`launchctl load "${PLIST}" 2>/dev/null || true`);
      else exec(`${BIN} -d "${CONFIG_DIR}" >> "${LOG}" 2>&1 &`);
    },
    forceKill()  { run(`pkill -KILL -f 'mihomo -d' 2>/dev/null || true`); },
    getPid()     { return run("pgrep -f 'mihomo -d'"); },
    killHint()   { return 'sudo kill $(pgrep -f "mihomo -d")'; },
    port7890Ok() {
      // netstat -an 不需要 root 权限，可见所有监听端口（含 root 进程）
      if (run('netstat -an 2>/dev/null | grep "127.0.0.1.7890.*LISTEN"')) return true;
      // 普通模式 fallback（非 root 启动时）
      return !!run('lsof -i :7890 -sTCP:LISTEN -n 2>/dev/null | grep -i mihomo | head -1');
    },
    hasGit()     { return !!run('which git 2>/dev/null'); },
    gitNull:       '2>/dev/null',
    extraOfflineStatus() {
      const launchd = run('launchctl list | grep mihomo');
      if (launchd) console.log(c.yellow('  LaunchAgent 已加载但进程未响应 API'));
    },

    // ── 开机自启 ──────────────────────────────────────────────
    isAutostartEnabled() { return fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED); },
    enableAutostart() {
      if (fs.existsSync(PLIST_DISABLED)) fs.renameSync(PLIST_DISABLED, PLIST);
      else if (!fs.existsSync(PLIST)) throw new Error('plist 文件不存在，请重新安装');
      run(`launchctl load "${PLIST}" 2>/dev/null || true`);
      console.log(c.green('✓ 已启用开机自启'));
      console.log(c.dim(`  plist: ${PLIST}`));
    },
    disableAutostart() {
      if (fs.existsSync(PLIST) && !fs.existsSync(PLIST_DISABLED)) {
        run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
        fs.renameSync(PLIST, PLIST_DISABLED);
      }
      console.log(c.dim('✓ 已禁用开机自启（当前进程不受影响）'));
      console.log(c.dim(`  plist 已更名为: ${PLIST_DISABLED}`));
    },

    // ── 系统代理 ──────────────────────────────────────────────
    getCurlProxyArg() {
      try {
        const sp = execSync('scutil --proxy 2>/dev/null', { encoding: 'utf8' });
        const httpsOn   = (sp.match(/HTTPSEnable\s*:\s*(\d+)/)  || [])[1] === '1';
        const httpsHost = (sp.match(/HTTPSProxy\s*:\s*(\S+)/)   || [])[1];
        const httpsPort = (sp.match(/HTTPSPort\s*:\s*(\d+)/)    || [])[1];
        if (httpsOn && httpsHost && httpsPort) return `-x "http://${httpsHost}:${httpsPort}"`;
        const socksOn   = (sp.match(/SOCKSEnable\s*:\s*(\d+)/) || [])[1] === '1';
        const socksHost = (sp.match(/SOCKSProxy\s*:\s*(\S+)/)  || [])[1];
        const socksPort = (sp.match(/SOCKSPort\s*:\s*(\d+)/)   || [])[1];
        if (socksOn && socksHost && socksPort) return `--socks5 "${socksHost}:${socksPort}"`;
      } catch {}
      return '';
    },
    isSystemProxyActive() {
      const out = run('scutil --proxy 2>/dev/null');
      return out.includes('HTTPProxy : 127.0.0.1') && out.includes('HTTPEnable : 1');
    },
    getActiveInterface() {
      const iface = run("route -n get default 2>/dev/null | awk '/interface:/{print $2}'").trim();
      if (iface) {
        const lines = run('networksetup -listallhardwareports 2>/dev/null').split('\n');
        let port = '';
        for (const line of lines) {
          const pm = line.match(/^Hardware Port:\s*(.+)/);
          if (pm) port = pm[1].trim();
          const dm = line.match(/^Device:\s*(.+)/);
          if (dm && dm[1].trim() === iface && port) return port;
        }
      }
      for (const svc of run('networksetup -listallnetworkservices').split('\n')
          .filter(s => s && !s.startsWith('An ') && !s.includes('*'))) {
        const info = run(`networksetup -getinfo "${svc}" 2>/dev/null`);
        const m = info.match(/^IP address:\s*(.+)$/m);
        if (m && m[1].trim() !== '(null)' && m[1].trim() !== '') return svc;
      }
      return 'Wi-Fi';
    },
    setSystemProxy(iface) {
      execSync(`sudo networksetup -setwebproxy "${iface}" 127.0.0.1 7890`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsecurewebproxy "${iface}" 127.0.0.1 7890`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsocksfirewallproxy "${iface}" 127.0.0.1 7890`, { stdio: ['inherit', 'pipe', 'pipe'] });
    },
    clearSystemProxy(iface) {
      execSync(`sudo networksetup -setwebproxystate "${iface}" off`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsecurewebproxystate "${iface}" off`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync(`sudo networksetup -setsocksfirewallproxystate "${iface}" off`, { stdio: ['inherit', 'pipe', 'pipe'] });
    },
    proxySuccessMsg(iface) { return `✓ 系统代理已接管 → 127.0.0.1:7890 (${iface})`; },

    // ── DNS ──────────────────────────────────────────────────
    checkDns1053() { return !!run('lsof -i UDP:1053 -n -P 2>/dev/null | grep -i mihomo'); },
    getDnsServers(iface) {
      const out = run(`networksetup -getdnsservers "${iface}" 2>/dev/null`);
      return out.trim().split('\n').map(l => l.trim()).filter(l => l && !/aren't|There/i.test(l));
    },
    setDnsToMihomo(iface) {
      execSync(`sudo networksetup -setdnsservers "${iface}" 127.0.0.1`, { stdio: ['inherit', 'pipe', 'pipe'] });
    },
    async restoreAll(iface, dnsToRestore) {
      // ⚠️ 顺序：先切到可用 DNS，再移除 pf anchor，避免 DNS 短暂中断
      let transit = dnsToRestore?.length ? dnsToRestore : null;
      if (!transit) {
        const gw = run(`netstat -rn | awk '/^default/{print $2; exit}'`).trim();
        transit = (gw && gw.match(/^\d+\.\d+\.\d+\.\d+/)) ? [gw] : ['8.8.8.8'];
      }
      const dnsArgs = transit.map(s => `"${s}"`).join(' ');
      execSync(`sudo networksetup -setdnsservers "${iface}" ${dnsArgs}`, { stdio: 'inherit' });
      run('dscacheutil -flushcache 2>/dev/null || true');
      await new Promise(r => setTimeout(r, 600));
      execSync(`sudo pfctl -a 'com.apple/mihomo-dns' -F nat`, { stdio: 'inherit' });
      try { fs.unlinkSync(PF_CONF); } catch {}
      return dnsToRestore?.length ? dnsToRestore.join(', ') : `${transit.join(', ')} (将随 DHCP 更新)`;
    },
    flushDns()        { run('dscacheutil -flushcache 2>/dev/null || true'); },
    isDnsActive(iface) { return this.getDnsServers(iface).includes('127.0.0.1'); },
    loadPfAnchor() {
      const conf = 'rdr on lo0 proto udp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053\n'
                 + 'rdr on lo0 proto tcp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053\n';
      fs.writeFileSync(PF_CONF, conf);
      execSync(`sudo pfctl -a 'com.apple/mihomo-dns' -f "${PF_CONF}"`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync('sudo pfctl -e 2>/dev/null || true', { stdio: 'pipe' });
      if (!run(`sudo pfctl -a 'com.apple/mihomo-dns' -sn 2>/dev/null`).includes('1053'))
        throw new Error('pf anchor 规则加载后验证失败');
    },
    isPfAnchorActive() { return run(`sudo pfctl -a 'com.apple/mihomo-dns' -sn 2>/dev/null`).includes('1053'); },
    printDnsStatus(iface) {
      const servers    = this.getDnsServers(iface);
      const mihomoIsDns = servers.includes('127.0.0.1');
      const port1053   = this.checkDns1053();
      const pfOk       = this.isPfAnchorActive();
      console.log(`  接口       : ${c.cyan(iface)}`);
      console.log(`  系统 DNS   : ${c.cyan(servers.length ? servers.join(', ') : '(DHCP 自动)')}`);
      console.log(`  Mihomo 监听 1053 : ${port1053 ? c.green('✓') : c.red('✗')}`);
      console.log(`  pf rdr anchor    : ${pfOk ? c.green('✓ 已加载') : c.red('✗ 未加载')}`);
      if (pfOk && mihomoIsDns && port1053) console.log(`  接管状态 : ${c.green('已接管（防污染 DNS 生效）')}`);
      else if (mihomoIsDns && !pfOk)       console.log(`  接管状态 : ${c.yellow('⚠ 系统 DNS=127.0.0.1 但 pf 规则未加载，运行 dns-on 修复')}`);
      else                                 console.log(`  接管状态 : ${c.dim('未接管（使用默认 DNS）')}`);
      const r = run('dig +short +time=2 cloudflare.com @127.0.0.1 -p 1053 2>/dev/null');
      console.log(`  实际解析测试 : ${r ? c.green('✓ ' + r.split('\n')[0]) : c.red('✗ 无响应')}`);
      if (!pfOk && mihomoIsDns) {
        console.log(c.dim('\n  pf anchor 已丢失（常见于睡眠/唤醒后），运行:'));
        console.log(c.cyan('  mihomo-ctl dns-on'));
      }
    },
    adminHint() {},
    dnsOnSuccess(_iface) {
      console.log(c.green('✓ DNS 已接管 → 127.0.0.1:1053 (Mihomo DoH)'));
      console.log(c.dim('  国内域名 → 阿里/腾讯 DoH (直连)'));
      console.log(c.dim('  国外域名 → 1.1.1.1 / Google DoH (走代理)'));
      console.log(c.dim('\n  关闭: mihomo-ctl dns-off'));
