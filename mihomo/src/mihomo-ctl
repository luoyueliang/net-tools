#!/usr/bin/env node
// mihomo-ctl - Mihomo 管理工具
// 用法: mihomo-ctl [status|start|stop|restart|proxies|test|log|help]

const { execSync, exec, spawn } = require('child_process');
const http = require('http');
const os   = require('os');
const path = require('path');
const fs   = require('fs');

const IS_WIN = process.platform === 'win32';

// ─── 路径常量（跨平台）────────────────────────────────────────
const VERSION     = '1.4.13';
const GITHUB_REPO = 'luoyueliang/net-tools';
const API         = 'http://127.0.0.1:9090';

// 配置目录：Windows 用 %APPDATA%\mihomo，Unix 用 ~/.config/mihomo
