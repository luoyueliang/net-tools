// FreeBSD 扩展适配器：pf DNS 接管（/etc/resolv.conf + pfctl anchor）+ sysrc 自启管理
function createFreeBSDAdapter(name, stopCmd, startCmd) {
  return {
    ...createServiceAdapter(name, stopCmd, startCmd),
    supportsDns:  true,
    supportsProxy: true,
    setSystemProxy(_iface)   { linuxProxyWriteRc(); },
    clearSystemProxy(_iface) { linuxProxyClearRc(); },
    isSystemProxyActive()    { return linuxRcProxyActive(); },
    proxySuccessMsg(_iface) {
      const files = getShellRcFiles().map(f => f.path.replace(os.homedir(), '~'));
      return `✓ 代理环境变量已写入 rc 文件: ${files.join(', ')}`;
    },

    // ── 开机自启（sysrc）─────────────────────────────────────
    isAutostartEnabled() { return run('sysrc -n mihomo_enable 2>/dev/null').trim().toUpperCase() === 'YES'; },
    enableAutostart()    { run('sudo sysrc mihomo_enable=YES 2>/dev/null || true'); console.log(c.green('✓ 已启用开机自启 (sysrc mihomo_enable=YES)')); },
    disableAutostart()   { run('sudo sysrc mihomo_enable=NO 2>/dev/null || true'); console.log(c.dim('✓ 已禁用开机自启')); },

    // ── 网络接口 ─────────────────────────────────────────────
    getActiveInterface() {
      return run("route get default 2>/dev/null | awk '/interface:/{print $2}'").trim() || 'em0';
    },

    // ── pf DNS 重定向（53 → 1053，与 macOS 一致）───────────
    checkDns1053() { return !!run('lsof -i UDP:1053 -n -P 2>/dev/null | grep -i mihomo'); },
    getDnsServers(_iface) {
      const out = run("awk '/^nameserver/{print $2}' /etc/resolv.conf 2>/dev/null");
      return out ? out.split('\n').filter(Boolean) : [];
    },
    setDnsToMihomo(_iface) {
      // 先备份 resolv.conf（-n 保证不覆盖已有备份）
      run('sudo cp -n /etc/resolv.conf /etc/resolv.conf.mihomo-bak 2>/dev/null');
      const tmpConf = path.join(TMP, 'mihomo-resolv.conf');
      const current = run('cat /etc/resolv.conf 2>/dev/null');
      const noNs    = current.split('\n').filter(l => !l.trim().startsWith('nameserver')).join('\n').trim();
      fs.writeFileSync(tmpConf, 'nameserver 127.0.0.1\n' + (noNs ? noNs + '\n' : ''));
      execSync(`sudo cp "${tmpConf}" /etc/resolv.conf`, { stdio: 'pipe' });
    },
    loadPfAnchor() {
      const conf = 'rdr on lo0 proto udp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053\n'
                 + 'rdr on lo0 proto tcp from any to 127.0.0.1 port 53 -> 127.0.0.1 port 1053\n';
      fs.writeFileSync(PF_CONF, conf);
      execSync(`sudo pfctl -a 'mihomo-dns' -f "${PF_CONF}"`, { stdio: ['inherit', 'pipe', 'pipe'] });
      execSync('sudo pfctl -e 2>/dev/null || true', { stdio: 'pipe' });
      if (!run(`sudo pfctl -a 'mihomo-dns' -sn 2>/dev/null`).includes('1053'))
        throw new Error('pf anchor 规则加载后验证失败');
    },
    isPfAnchorActive() { return run(`sudo pfctl -a 'mihomo-dns' -sn 2>/dev/null`).includes('1053'); },
    async restoreAll(_iface, _dns) {
      run(`sudo pfctl -a 'mihomo-dns' -F nat 2>/dev/null || true`);
      try { fs.unlinkSync(PF_CONF); } catch {}
      // 优先从文件备份恢复
      if (fs.existsSync('/etc/resolv.conf.mihomo-bak')) {
        run('sudo mv /etc/resolv.conf.mihomo-bak /etc/resolv.conf 2>/dev/null');
        const servers = run("awk '/^nameserver/{print $2}' /etc/resolv.conf 2>/dev/null");
        return servers ? servers.split('\n').filter(Boolean).join(', ') : '（已从备份恢复）';
      }
      // 从 dns-on 时保存的列表恢复
      if (_dns && _dns.length) {
        const tmpConf = path.join(TMP, 'mihomo-resolv.conf');
        const current = run('cat /etc/resolv.conf 2>/dev/null');
        const noNs    = current.split('\n').filter(l => !l.trim().startsWith('nameserver')).join('\n').trim();
        fs.writeFileSync(tmpConf, _dns.map(s => `nameserver ${s}`).join('\n') + '\n' + (noNs ? noNs + '\n' : ''));
        execSync(`sudo cp "${tmpConf}" /etc/resolv.conf`, { stdio: 'pipe' });
        return _dns.join(', ');
      }
      return '（pf anchor 已移除，resolv.conf 未变更）';
    },
    flushDns() { run('resolvconf -u 2>/dev/null || true'); },
    isDnsActive(_iface) { return this.isPfAnchorActive() && this.getDnsServers().includes('127.0.0.1'); },
    printDnsStatus(_iface) {
      const servers     = this.getDnsServers();
      const mihomoIsDns = servers.includes('127.0.0.1');
      const port1053    = this.checkDns1053();
      const pfOk        = this.isPfAnchorActive();
      console.log(`  系统 DNS (/etc/resolv.conf) : ${c.cyan(servers.length ? servers.join(', ') : '(未知)')}`);
      console.log(`  Mihomo 监听 1053       : ${port1053 ? c.green('✓') : c.red('✗')}`);
      console.log(`  pf rdr anchor          : ${pfOk ? c.green('✓ 已加载') : c.red('✗ 未加载')}`);
      if (pfOk && mihomoIsDns && port1053)
        console.log(`  接管状态 : ${c.green('已接管（pf 重定向）')}`);
      else if (mihomoIsDns && !pfOk)
        console.log(`  接管状态 : ${c.yellow('⚠ resolv.conf=127.0.0.1 但 pf 规则未加载，运行 dns-on 修复')}`);
      else
        console.log(`  接管状态 : ${c.dim('未接管')}`);
    },
    adminHint() { console.log(c.dim('  需要 sudo 权限')); },
    dnsOnSuccess(_iface) {
      console.log(c.green('✓ DNS 已接管 → 127.0.0.1:1053 (Mihomo DoH)'));
      console.log(c.dim('  关闭: mihomo-ctl dns-off'));
    },
    dnsOnErrorHint(_iface) {
      this.adminHint();
      console.log(c.cyan(`  sudo pfctl -a 'mihomo-dns' -f "${PF_CONF}" && sudo pfctl -e`));
    },
  };
}

