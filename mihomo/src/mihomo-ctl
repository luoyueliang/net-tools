// ANSI 颜色
const c = {
  green: s => `\x1b[32m${s}\x1b[0m`,
  red:   s => `\x1b[31m${s}\x1b[0m`,
  yellow:s => `\x1b[33m${s}\x1b[0m`,
  cyan:  s => `\x1b[36m${s}\x1b[0m`,
  bold:  s => `\x1b[1m${s}\x1b[0m`,
  dim:   s => `\x1b[2m${s}\x1b[0m`,
};

function apiGet(path) {
  return new Promise((resolve, reject) => {
    const req = http.get(`${API}${path}`, { timeout: 3000 }, res => {
      let data = '';
      res.on('data', d => data += d);
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch { resolve(data); }
      });
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
  });
}

function apiPut(path, body) {
  return new Promise((resolve, reject) => {
    const data = JSON.stringify(body);
    const opts = {
      hostname: '127.0.0.1', port: 9090, path, method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) },
      timeout: 3000,
    };
    const req = http.request(opts, res => {
      let d = '';
      res.on('data', c => d += c);
      res.on('end', () => resolve({ status: res.statusCode, body: d }));
    });
    req.on('error', reject);
    req.on('timeout', () => { req.destroy(); reject(new Error('timeout')); });
    req.write(data);
    req.end();
  });
}

function run(cmd) {
  try { return execSync(cmd, { encoding: 'utf8', shell: IS_WIN ? 'cmd.exe' : '/bin/sh' }).trim(); }
  catch { return ''; }
}

// ─── 平台适配器注册表 ─────────────────────────────────────────
// 所有平台相关的原子操作按平台集中封装，命令函数调用 P.xxx()，无需 if/else

function detectPlatform() {
  if (IS_WIN) return 'windows';
  if (process.platform === 'darwin') return 'macos';
  if (fs.existsSync('/etc/alpine-release'))  return 'alpine';
  if (fs.existsSync('/etc/openwrt_release')) return 'openwrt';
  if (process.platform === 'linux')   return 'linux';
  if (process.platform === 'freebsd') return 'freebsd';
  return 'linux';
}

// 工厂：为 systemd / OpenRC / rc.d 等 Linux 系列生成基础适配器
function createServiceAdapter(name, stopCmd, startCmd) {
  return {
    name, supportsProxy: false, supportsDns: false,

    // ── 进程 ──────────────────────────────────────────────────
    stopProcess()  { run(stopCmd);  },
    startProcess() { run(startCmd); },
    forceKill()    { run(`pkill -KILL -f 'mihomo -d' 2>/dev/null || true`); },
    getPid()       { return run("pgrep -f 'mihomo -d'"); },
    killHint()     { return 'sudo kill $(pgrep -f "mihomo -d")'; },
    port7890Ok()   { return !!run('ss -tlnp 2>/dev/null | grep :7890 || lsof -i :7890 -sTCP:LISTEN -n 2>/dev/null | grep mihomo'); },
    hasGit()       { return !!run('which git 2>/dev/null'); },
    gitNull:         '2>/dev/null',
    extraOfflineStatus() {},

    // ── 开机自启 ──────────────────────────────────────────────
    isAutostartEnabled()  { return false; },
    enableAutostart()     { console.log(c.yellow('⚠ 请使用系统服务管理器配置自启')); },
    disableAutostart()    { console.log(c.yellow('⚠ 请使用系统服务管理器配置自启')); },

    // ── 系统代理 ──────────────────────────────────────────────
    getCurlProxyArg()       { return ''; },
    isSystemProxyActive()   { return false; },
    getActiveInterface()    { return null; },
    setSystemProxy()        { throw new Error('不支持'); },
    clearSystemProxy()      { throw new Error('不支持'); },
    proxySuccessMsg()       { return '✓ 系统代理已接管 → 127.0.0.1:7890'; },

    // ── DNS ──────────────────────────────────────────────────
    checkDns1053()  { return !!run('lsof -i UDP:1053 -n -P 2>/dev/null | grep -i mihomo'); },
    getDnsServers() { return []; },
    setDnsToMihomo() { throw new Error('不支持'); },
    async restoreAll() { throw new Error('平台不支持 DNS 管理'); },
    flushDns()        { run('resolvectl flush-caches 2>/dev/null || nscd -K 2>/dev/null || true'); },
    isDnsActive()     { return false; },
    printDnsStatus()  { console.log(c.yellow(`⚠ 当前平台 (${this.name}) 不支持 DNS 管理`)); },
    adminHint()       {},
    dnsOnSuccess(_iface) { console.log(c.dim('  关闭: mihomo-ctl dns-off')); },
    dnsOnErrorHint(_iface) {},

    // ── 升级 ─────────────────────────────────────────────────
    upgradeAsset(osName, arch, latest) {
      return {
        url:    `https://github.com/MetaCubeX/mihomo/releases/download/${latest}/mihomo-${osName}-${arch}-${latest}.gz`,
        tmpPkg: path.join(TMP, `mihomo-new-${latest}.gz`),
        tmpBin: path.join(TMP, `mihomo-new-${latest}`),
        bkBin:  path.join(TMP, `mihomo-old-${latest}`),
      };
    },
    extractAsset(tmpPkg, tmpBin) {
      run(`gunzip -f "${tmpPkg}"`);
      if (!fs.existsSync(tmpBin)) throw new Error('解压失败');
      run(`chmod +x "${tmpBin}"`);
    },
    installBin(tmpBin)  { execSync(`sudo mv "${tmpBin}" "${BIN}"`, { stdio: 'pipe' }); },
    backupBin(bkBin)    { if (fs.existsSync(BIN)) run(`sudo cp "${BIN}" "${bkBin}" 2>/dev/null`); },
    rollbackBin(bkBin)  { run(`sudo mv "${bkBin}" "${BIN}" 2>/dev/null || true`); },
    upgradeRollbackHint(bkBin) { return `sudo mv "${bkBin}" "${BIN}" && mihomo-ctl restart`; },
    installSelf(tmp, self, bak) {
      execSync(`sudo cp "${self}" "${bak}"`, { stdio: 'pipe' });
      execSync(`sudo mv "${tmp}" "${self}"`, { stdio: 'pipe' });
      execSync(`sudo chmod 755 "${self}"`, { stdio: 'pipe' });
    },
    selfRollbackHint(bak, self) { return `sudo mv "${bak}" "${self}"`; },
  };
}

const PLATFORM_ADAPTERS = {
  // ════════════════════════════════════════════════════════════
  //  macOS
  // ════════════════════════════════════════════════════════════
  macos: {
    name: 'macos', supportsProxy: true, supportsDns: true,

    // ── 进程 ──────────────────────────────────────────────────
    stopProcess() {
      run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
      run(`pkill -f 'mihomo -d' 2>/dev/null || true`);
    },
