    req.write(body); req.end();
  });
}

// ─── 命令：tun-on / tun-off ──────────────────────────────────
function setTunEnable(cfgText, enable) {
  const tunIdx    = cfgText.indexOf('\ntun:\n');
  if (tunIdx === -1) return null;
  const enableIdx = cfgText.indexOf('\n  enable:', tunIdx);
  if (enableIdx === -1) return null;
  const lineEnd   = cfgText.indexOf('\n', enableIdx + 1);
  const line      = cfgText.slice(enableIdx, lineEnd);
  const newLine   = line.replace(/(enable:\s*)(true|false)/, `$1${enable}`);
  return cfgText.slice(0, enableIdx) + newLine + cfgText.slice(lineEnd);
}

async function cmdTunOn() {
  if (P.name === 'windows') {
    console.log(c.yellow('⚠ tun-on 当前不支持 Windows 平台'));
    return;
  }
  if (!(await isRunning())) { console.log(c.red('请先启动 Mihomo: mihomo-ctl start')); return; }
  const cfgText = fs.readFileSync(CONFIG, 'utf8');
  const tunIdx  = cfgText.indexOf('\ntun:\n');
  if (tunIdx === -1) { console.log(c.red('✗ 配置中缺少 tun: 块，请检查 config.yaml')); return; }
  const enableIdx = cfgText.indexOf('\n  enable:', tunIdx);
  const lineEnd   = cfgText.indexOf('\n', enableIdx + 1);
  if (/enable:\s*true/.test(cfgText.slice(enableIdx, lineEnd))) {
    // yaml 已是 true，但运行中进程是否真的加载了 TUN？
    const runCfg = await apiGet('/configs').catch(() => ({}));
    if (runCfg.tun?.enable === true) { console.log(c.green('✓ TUN 已处于开启状态')); return; }
    console.log(c.dim('  TUN 配置已启用但运行中进程未加载（可能存在遗留进程），正在重启...'));
  }
  const newCfg = setTunEnable(cfgText, 'true');
  fs.writeFileSync(CONFIG, newCfg);
  console.log(c.bold('\n── 开启 TUN 透明代理 ─────────────────────────────'));
  // 先停止旧进程：macOS 额外 unload LaunchAgent，Linux/Alpine 先 stop 服务
  if (P.name === 'macos') {
    run(`launchctl unload "${PLIST}" 2>/dev/null || true`);
  } else {
    P.stopProcess();
  }
  P.forceKill();
  await new Promise(r => setTimeout(r, 1200));
  console.log(c.dim('  以 sudo 启动（TUN auto-route 需 root 权限）...'));
  spawn('sudo', [BIN, '-d', CONFIG_DIR], { detached: true, stdio: 'ignore' }).unref();
  await new Promise(r => setTimeout(r, 2000));
  if (await isRunning()) {
    fs.writeFileSync(TUN_STATE_FILE, '1');
    console.log(c.green('✓ TUN 模式已开启（所有 TCP/UDP 流量透明接管）'));
    console.log(c.dim('  Telegram 等不走系统代理的 App 现在会经过规则路由'));
    console.log(c.dim('  关闭: mihomo-ctl tun-off'));
  } else {
    fs.writeFileSync(CONFIG, cfgText);
    P.startProcess();
    await new Promise(r => setTimeout(r, 1500));
    console.log(c.red('✗ TUN 模式启动失败（sudo 可能需要密码）'));
    console.log(c.dim('\n  在 /etc/sudoers 中添加免密授权 (sudo visudo):'));
    console.log(c.cyan(`    ${os.userInfo().username} ALL=(ALL) NOPASSWD: ${BIN}`));
    console.log(c.dim('  或手动以 root 运行:'));
    console.log(c.cyan(`    sudo ${BIN} -d ${CONFIG_DIR}`));
  }
}

async function cmdTunOff() {
  if (P.name === 'windows') {
    console.log(c.yellow('⚠ tun-off 当前不支持 Windows 平台'));
    return;
  }
  let cfgText = fs.readFileSync(CONFIG, 'utf8');
  const newCfg = setTunEnable(cfgText, 'false');
  if (newCfg) fs.writeFileSync(CONFIG, newCfg);
  console.log(c.bold('\n── 关闭 TUN 透明代理 ─────────────────────────────────────────────────────────'));
  // 杀掉 root TUN 进程（sudo pkill 覆盖 root 进程，普通 pkill 覆盖非 root 进程）
  run(`sudo pkill -f 'mihomo -d' 2>/dev/null || pkill -f 'mihomo -d' 2>/dev/null || true`);
  try { fs.unlinkSync(TUN_STATE_FILE); } catch {}
  if (P.name === 'macos') {
    // macOS：startProcess 异步不可靠，提示用户手动 start
    console.log(c.green('✓ TUN 模式已关闭'));
    console.log(c.yellow('  请等待约 10 秒后运行: mihomo-ctl start'));
  } else {
    // Linux/Alpine：P.startProcess() 同步（systemctl/rc-service），可立即验证
    P.startProcess();
    await new Promise(r => setTimeout(r, 1000));
    if (await isRunning()) {
      console.log(c.green('✓ TUN 模式已关闭'));
      console.log(c.dim('  Mihomo 已恢复普通模式（系统代理）'));
    } else {
      console.log(c.yellow('⚠ TUN 已关闭，请手动启动: mihomo-ctl start'));
    }
  }
}

