// ─── 入口 ──────────────────────────────────────────────────────
const [,, cmd, ...args] = process.argv;

(async () => {
  switch (cmd) {
    case 'status':  await cmdStatus();  break;
    case 'proxies': await cmdProxies(); break;
    case 'test':    await cmdTest();    break;
    case 'select':  await cmdSelect(args[0], args[1]); break;
    case 'start':      await cmdStart();     break;
    case 'stop':       await cmdStop();      break;
    case 'restart':    await cmdRestart();   break;
    case 'reload':     await cmdReload();    break;
    case 'upgrade':    await cmdUpgrade();   break;
    case 'check':      cmdCheck();           break;
    case 'mode':       await cmdMode(args[0]); break;
    case 'geo':        await cmdGeo(args[0]); break;
    case 'traffic':    await cmdTraffic();   break;
    case 'connections': await cmdConnections(args[0]); break;
    case 'backup':     cmdBackup();          break;
    case 'restore':    cmdRestore(args[0]);  break;
    case 'ui':         await cmdUi(args[0]); break;
    case 'autostart':  cmdAutostart(args[0]); break;
    case 'log':        cmdLog();             break;
    case 'log-on':     await cmdLogOn();     break;
    case 'log-off':    await cmdLogOff();    break;
    case 'proxy-on':   await cmdProxyOn();   break;
    case 'proxy-off':  await cmdProxyOff();  break;
    case 'dns-on':     await cmdDnsOn();     break;
    case 'dns-off':    await cmdDnsOff();    break;
    case 'dns':        await cmdDnsStatus(); break;
    case 'help': case '--help': case '-h': cmdHelp(); break;
    default:
      await cmdStatus();
      console.log(c.dim('\n运行 mihomo-ctl help 查看所有命令'));
  }
})();
